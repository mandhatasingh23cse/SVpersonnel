<section class="page-hero">
  <div class="shell page-hero-content">
    <p class="eyebrow">Partner Portal</p>
    <h1>Manage your professional profile.</h1>
    <p>Update your details, select the services you offer, manage security, or delete your profile.</p>
  </div>
</section>

<section class="section shell dashboard-shell">
  <%- include("partials/notice") %>

  <div style="display: grid; grid-template-columns: 1fr; gap: 3rem; max-width: 800px; margin: 0 auto;">
    <!-- Profile Information Form -->
    <article class="glass-panel" style="padding: 2.5rem; border-radius: var(--radius-lg);">
      <p class="card-kicker">Professional Profile</p>
      <h2 style="margin-bottom: 1.5rem;">Edit Professional Details</h2>

      <form method="POST" action="/professional/profile" class="auth-form" enctype="multipart/form-data">
        <div class="form-row">
          <label class="field-group">
            <span>Full name</span>
            <input type="text" name="fullname" value="<%= profile.name %>" required>
          </label>

          <label class="field-group">
            <span>Email Address</span>
            <input type="email" value="<%= profile.email %>" disabled style="background: rgba(0, 0, 0, 0.05); cursor: not-allowed;">
          </label>
        </div>

        <div class="form-row">
          <label class="field-group">
            <span>Phone number</span>
            <input type="tel" name="phone" value="<%= profile.phone %>" placeholder="e.g. 9876543210" required>
          </label>

          <label class="field-group">
            <span>Pincode</span>
            <input type="text" name="pincode" id="prof_pincode" maxlength="6" value="<%= profile.pincode || '' %>" placeholder="e.g. 226006">
          </label>
        </div>

        <div class="form-row">
          <label class="field-group">
            <span>City</span>
            <input type="text" name="city" id="prof_city" value="<%= profile.city %>" required>
          </label>

          <label class="field-group">
            <span>Locality / Area</span>
            <input type="text" name="area" id="prof_area" value="<%= profile.area || '' %>" placeholder="Exact area/sector">
          </label>

        <div class="form-row">
          <label class="field-group">
            <span>Years of experience</span>
            <input type="number" name="experience" value="<%= profile.experience %>" min="0" max="60" required>
          </label>
        </div>

        <label class="field-group">
          <span>Profile photo (Choose from Gallery)</span>
          <input type="file" id="photo" name="photo" accept="image/*">
          <% if (profile.photo && profile.photo !== '/assets/gigconnect.logo.png') { %>
            <small style="color: var(--text-muted); display: block; margin-top: 0.5rem;">Current Photo: <a href="<%= profile.photo %>" target="_blank" style="color: var(--accent); font-weight: 600;">View Image</a></small>
          <% } %>
        </label>

        <label class="field-group">
          <span>Short professional biography</span>
          <textarea name="description" rows="4" placeholder="Tell clients about your expertise, tools, and background..."><%= profile.description %></textarea>
        </label>

        <!-- Step 1: Work Modes & Pricing Configuration Upfront -->
        <div id="hiring-modes-section" style="margin: 2rem 0 1.5rem 0; border-top: 1px solid var(--line); padding-top: 1.5rem;">
          <div style="background: rgba(139, 92, 246, 0.12); border: 1px solid rgba(167, 139, 250, 0.4); border-radius: var(--radius-sm); padding: 0.75rem 1rem; margin-bottom: 1.25rem;">
            <p style="margin: 0; color: #f3f4f6; font-size: 0.92rem; font-weight: 600;">
              ✨ <strong>Step 1: Select Work Modes First</strong> — Choose whether you provide Part Time visits, Full Time monthly placements, or Both. Your pricing boxes below will dynamically update according to what you select here!
            </p>
          </div>

          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem; color: #fff;">Hiring Modes & Base Charges</h3>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.25rem;">Select which hiring modes you provide right upfront:</p>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
            <!-- Part Time Card -->
            <div style="background: rgba(15, 23, 42, 0.85); border: 1px solid rgba(56, 189, 248, 0.4); border-radius: var(--radius-md); padding: 1.25rem; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
              <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-weight: 700; color: #38bdf8; font-size: 1.05rem; margin-bottom: 0.75rem;">
                <input type="checkbox" id="profile-pt-checkbox" name="workModes" value="Part Time" <%= (!profile.workModes || profile.workModes.includes('Part Time')) ? 'checked' : '' %> style="width: 20px; height: 20px; accent-color: #38bdf8;">
                <span>Provide Part Time Booking</span>
              </label>
              <p style="font-size: 0.82rem; color: #94a3b8; margin-bottom: 1rem;">For daily visits, short tasks, or fixed daily service bookings.</p>
              <label class="field-group" style="margin: 0;">
                <span style="font-size: 0.85rem;">Base Part-Time Charge (₹ / Day)</span>
                <input type="number" name="partTimeRate" id="base-part-time-rate" value="<%= profile.partTimeRate || profile.hourlyRateInr || 500 %>" min="100" max="100000" style="background: rgba(0,0,0,0.5); color: #fff; font-weight: 700; border: 1px solid rgba(56,189,248,0.3);">
              </label>
            </div>

            <!-- Full Time Card -->
            <div style="background: rgba(15, 23, 42, 0.85); border: 1px solid rgba(168, 85, 247, 0.4); border-radius: var(--radius-md); padding: 1.25rem; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
              <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-weight: 700; color: #d8b4fe; font-size: 1.05rem; margin-bottom: 0.75rem;">
                <input type="checkbox" id="profile-ft-checkbox" name="workModes" value="Full Time" <%= (profile.workModes && profile.workModes.includes('Full Time')) ? 'checked' : '' %> style="width: 20px; height: 20px; accent-color: #a855f7;">
                <span>Provide Full Time Hiring</span>
              </label>
              <p style="font-size: 0.82rem; color: #94a3b8; margin-bottom: 1rem;">For monthly contracts or permanent dedicated placement.</p>
              <label class="field-group" style="margin: 0;">
                <span style="font-size: 0.85rem;">Expected Full-Time Charge (₹ / Month)</span>
                <input type="number" name="fullTimeRate" id="base-full-time-rate" value="<%= profile.fullTimeRate || 25000 %>" min="1000" max="500000" style="background: rgba(0,0,0,0.5); color: #fff; font-weight: 700; border: 1px solid rgba(168,85,247,0.3);">
              </label>
            </div>
          </div>
        </div>

        <!-- Step 2 & 3: Category -> Subcategory -> Custom Pricing (PT & FT) -->
        <div style="margin: 2rem 0 1.5rem 0; border-top: 1px solid var(--line); padding-top: 1.5rem;">
          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem; color: #fff;">Step 2: Select Category &amp; Subcategories &amp; Custom Skill Pricing</h3>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.25rem;">First select your primary service categories, tick all relevant subcategory skills, and customize your Part-Time and/or Full-Time pricing for each:</p>
          
          <!-- Detailed Categories & Subcategories Accordion -->
          <% if (typeof ottCategories !== 'undefined' && ottCategories && ottCategories.length > 0) { %>
            <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
              <% ottCategories.forEach(function(cat, idx) { %>
                <details class="glass-inset" style="border-radius: 14px; padding: 1rem 1.25rem; border: 1px solid rgba(255,255,255,0.12); background: rgba(15, 23, 42, 0.75);" <%= idx === 0 ? 'open' : '' %>>
                  <summary style="font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: space-between; color: #fff; font-size: 1.05rem;">
                    <span style="display: flex; align-items: center; gap: 0.5rem;">
                      <span style="font-size: 1.3rem;"><%= cat.headerIcon || '🔹' %></span>
                      <span><%= cat.title %></span>
                    </span>
                    <span style="font-size: 0.78rem; font-weight: 600; color: #38bdf8; background: rgba(56,189,248,0.15); padding: 4px 10px; border-radius: 12px; border: 1px solid rgba(56,189,248,0.3);">
                      <%= (cat.items || []).length %> Subcategory Skills ›
                    </span>
                  </summary>

                  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 1rem; margin-top: 1.1rem; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.1);">
                    <% (cat.items || []).forEach(function(item) { %>
                      <% 
                        const isSubChecked = (profile.subcategorySkills && profile.subcategorySkills.includes(item.name)) || (profile.skills && profile.skills.includes(item.name));
                        const safeKey = encodeURIComponent(item.name);
                        const subPtRate = (profile.customRates && profile.customRates['sub_pt_' + item.name]) ? profile.customRates['sub_pt_' + item.name] : '';
                        const subFtRate = (profile.customRates && profile.customRates['sub_ft_' + item.name]) ? profile.customRates['sub_ft_' + item.name] : '';
                      %>
                      <div style="padding: 0.95rem; border-radius: 12px; background: rgba(15, 23, 42, 0.95); border: 1px solid <%= isSubChecked ? '#a855f7' : 'rgba(255,255,255,0.12)' %>; transition: all 0.2s ease; display: flex; flex-direction: column; gap: 0.75rem;">
                        <label style="display: flex; align-items: flex-start; gap: 0.65rem; cursor: pointer;">
                          <input type="checkbox" name="subcategorySkills" value="<%= item.name %>" <%= isSubChecked ? 'checked' : '' %> class="subskill-checkbox" style="width: 18px; height: 18px; margin-top: 2px; accent-color: #a855f7;">
                          <div>
                            <strong style="color: #fff; font-size: 0.95rem; display: block;"><%= item.name %></strong>
                            <small style="color: #94a3b8; font-size: 0.78rem;"><%= item.desc %></small>
                          </div>
                        </label>

                        <div class="pricing-inputs-container" style="display: flex; flex-direction: column; gap: 0.5rem; padding-left: 1.6rem;">
                          <!-- Part Time Custom Rate -->
                          <div class="pt-rate-input" style="display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; background: rgba(56,189,248,0.08); padding: 4px 8px; border-radius: 6px; border: 1px solid rgba(56,189,248,0.2);">
                            <span style="font-size: 0.78rem; color: #38bdf8; font-weight: 600;">Part-Time (₹/day):</span>
                            <input type="number" name="customSubRate_<%= safeKey %>" placeholder="<%= profile.partTimeRate || 500 %>" value="<%= subPtRate %>" min="100" max="100000" style="width: 95px; padding: 4px 6px; font-size: 0.85rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.6); color: #fff; font-weight: 700; text-align: right;">
                          </div>

                          <!-- Full Time Custom Rate -->
                          <div class="ft-rate-input" style="display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; background: rgba(168,85,247,0.08); padding: 4px 8px; border-radius: 6px; border: 1px solid rgba(168,85,247,0.2);">
                            <span style="font-size: 0.78rem; color: #d8b4fe; font-weight: 600;">Full-Time (₹/mo):</span>
                            <input type="number" name="customSubFullRate_<%= safeKey %>" placeholder="<%= profile.fullTimeRate || 25000 %>" value="<%= subFtRate %>" min="1000" max="500000" style="width: 95px; padding: 4px 6px; font-size: 0.85rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.6); color: #fff; font-weight: 700; text-align: right;">
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </details>
              <% }) %>
            </div>
          <% } %>

          <!-- Primary Core Services Catalog -->
          <h4 style="font-size: 1.05rem; color: #fff; margin-bottom: 0.75rem;">Core Service Categories &amp; Base Custom Skill Rates</h4>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
            <% services.forEach(function(service) { %>
              <% 
                const isChecked = mappedServiceIds.includes(service.id);
                const customLink = (typeof mappedServices !== 'undefined' ? mappedServices.find(m => m.id === service.id) : null);
                const ptRateVal = (customLink && customLink.priceInr) ? customLink.priceInr : ((profile.customRates && profile.customRates['pt_' + service.id]) ? profile.customRates['pt_' + service.id] : '');
                const ftRateVal = (profile.customRates && profile.customRates['ft_' + service.id]) ? profile.customRates['ft_' + service.id] : '';
              %>
              <div style="padding: 0.9rem; border-radius: 12px; background: rgba(15, 23, 42, 0.88); border: 1px solid <%= isChecked ? 'var(--accent)' : 'rgba(255, 255, 255, 0.15)' %>; transition: all 0.2s ease; display: flex; flex-direction: column; gap: 0.65rem;">
                <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
                  <input type="checkbox" name="serviceIds" value="<%= service.id %>" <%= isChecked ? 'checked' : '' %> style="width: 18px; height: 18px; accent-color: var(--accent);">
                  <span style="font-size: 0.95rem; font-weight: 700; color: #ffffff;"><%= service.name %></span>
                </label>
                
                <div class="pricing-inputs-container" style="display: flex; flex-direction: column; gap: 0.5rem; padding-left: 1.75rem;">
                  <div class="pt-rate-input" style="display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;">
                    <span style="font-size: 0.8rem; color: #38bdf8; white-space: nowrap;">Part-Time (₹/day):</span>
                    <input type="number" name="customRate_<%= service.id %>" placeholder="<%= profile.partTimeRate || profile.hourlyRateInr || 500 %>" value="<%= ptRateVal %>" min="100" max="100000" style="width: 95px; padding: 4px 8px; font-size: 0.85rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.5); color: #fff; text-align: right;">
                  </div>
                  <div class="ft-rate-input" style="display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;">
                    <span style="font-size: 0.8rem; color: #d8b4fe; white-space: nowrap;">Full-Time (₹/mo):</span>
                    <input type="number" name="customFullRate_<%= service.id %>" placeholder="<%= profile.fullTimeRate || 25000 %>" value="<%= ftRateVal %>" min="1000" max="500000" style="width: 95px; padding: 4px 8px; font-size: 0.85rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.5); color: #fff; text-align: right;">
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

          <!-- Add Custom Skill Option -->
          <div style="margin-top: 1.5rem; padding: 1rem 1.25rem; border-radius: var(--radius-sm); background: rgba(139, 92, 246, 0.1); border: 1px dashed var(--accent);">
            <label for="customSkillName" style="display: block; font-weight: 600; color: #a78bfa; margin-bottom: 0.5rem; font-size: 0.95rem;">
              + Other (Add a Custom Skill / Service not listed above)
            </label>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.75rem;">If your skill is missing from the list, type it below. It will be automatically added and mapped to your profile when you click Save.</p>
            <input type="text" id="customSkillName" name="customSkillName" placeholder="e.g. Catering Chef, Solar Panel Installation..." style="max-width: 400px; background: rgba(15, 23, 42, 0.9); border: 1px solid rgba(255, 255, 255, 0.3); color: #ffffff;">
          </div>
        </div>

        <script>
          function updateModeVisibility() {
            const ptChecked = document.getElementById('profile-pt-checkbox')?.checked || false;
            const ftChecked = document.getElementById('profile-ft-checkbox')?.checked || false;

            document.querySelectorAll('.pt-rate-input').forEach(el => {
              el.style.display = ptChecked ? 'flex' : 'none';
            });
            document.querySelectorAll('.ft-rate-input').forEach(el => {
              el.style.display = ftChecked ? 'flex' : 'none';
            });
          }

          document.addEventListener('DOMContentLoaded', () => {
            updateModeVisibility();
            document.getElementById('profile-pt-checkbox')?.addEventListener('change', updateModeVisibility);
            document.getElementById('profile-ft-checkbox')?.addEventListener('change', updateModeVisibility);
          });
        </script>

        <button type="submit" class="button button-primary" style="margin-top: 1rem;">Save &amp; Update Profile &amp; Charges</button>
      </form>
    </article>

    <!-- Change Password Form -->
    <article class="glass-panel" style="padding: 2.5rem; border-radius: var(--radius-lg);">
      <p class="card-kicker">Security</p>
      <h2 style="margin-bottom: 1.5rem;">Change Password</h2>

      <form method="POST" action="/professional/change-password" class="auth-form">
        <label class="field-group">
          <span>New Password</span>
          <input type="password" name="newPassword" placeholder="Minimum 6 characters" required>
        </label>

        <button type="submit" class="button button-secondary" style="margin-top: 1rem;">Update Password</button>
      </form>
    </article>
  </div>
</section>
