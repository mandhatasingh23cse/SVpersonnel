<section class="section shell auth-layout">
  <div class="glass-panel auth-story" data-reveal>
    <p class="eyebrow">Professional login</p>
    <h1><%= authContent.title %></h1>
    <p><%= authContent.description %></p>
  </div>

  <div class="glass-panel auth-form-card" data-reveal>
    <p class="card-kicker">Log in</p>
    <h2>Manage your professional profile.</h2>

    <%- include("partials/notice") %>
    <% if (bridgeNote) { %>
      <div class="auth-note glass-inset">
        <p><%= bridgeNote %></p>
      </div>
    <% } %>

    <form class="auth-form" action="/professionallogin" method="POST">
      <label class="field-group">
        <span>Email or phone number</span>
        <input type="text" id="email" name="email" value="<%= formData.email %>" required>
      </label>

      <label class="field-group">
        <span style="display: flex; justify-content: space-between; align-items: center;">
          Password
          <a href="/reset-password" style="font-size: 0.8rem; font-weight: 500; color: var(--color-brand);">Forgot password?</a>
        </span>
        <div style="position: relative;">
          <input type="password" id="password" name="password" required style="width: 100%; padding-right: 4.5rem;">
          <button type="button" class="toggle-password-btn" data-toggle-target="password" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); background: none; border: none; font-size: 0.8rem; font-weight: 600; color: var(--color-brand); cursor: pointer;">Show</button>
        </div>
      </label>

      <label class="toggle-row">
        <span>Remember me on this device</span>
        <input type="checkbox" id="remember" name="remember">
      </label>

      <button type="submit" class="button button-primary button-block">Log in</button>
    </form>

    <div style="display: flex; align-items: center; justify-content: center; gap: 1rem; margin-top: 1.5rem; margin-bottom: 1.5rem;">
      <hr style="flex-grow: 1; border: 0; border-top: 1px solid rgba(255,255,255,0.1);">
      <span style="font-size: 0.85rem; color: var(--color-ink-light); font-weight: 500;">or</span>
      <hr style="flex-grow: 1; border: 0; border-top: 1px solid rgba(255,255,255,0.1);">
    </div>

    <a href="/auth/google?role=professional" class="button button-secondary button-block google-auth-btn" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; border-color: rgba(255,255,255,0.25); background: rgba(255,255,255,0.05); color: var(--color-ink); text-decoration: none;">
      <svg width="18" height="18" viewBox="0 0 18 18" style="vertical-align: middle;">
        <path fill="#EA4335" d="M9 3.6c1.62 0 3.06.56 4.21 1.64l3.15-3.15C14.45 1.07 11.97 0 9 0 5.48 0 2.44 2.02.94 4.96l3.69 2.87C5.51 5.33 7.07 3.6 9 3.6z"/>
        <path fill="#4285F4" d="M17.64 9.2c0-.59-.05-1.17-.16-1.73H9v3.29h4.84c-.21 1.12-.84 2.07-1.79 2.7l3.69 2.87c2.16-1.99 3.4-4.92 3.4-8.13z"/>
        <path fill="#FBBC05" d="M4.63 10.79a5.4 5.4 0 0 1 0-3.58L.94 4.34A8.99 8.99 0 0 0 0 9c0 1.67.46 3.23 1.25 4.58l3.38-2.79z"/>
        <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-3.69-2.87c-1.02.68-2.33 1.09-3.79 1.09-2.48 0-4.57-1.68-5.32-3.95L.77 12.96C2.26 15.93 5.37 18 9 18z"/>
      </svg>
      Continue with Google
    </a>

    <p class="auth-switch">Need a profile? <a href="/register">Join SV Personnels</a></p>
  </div>
</section>
