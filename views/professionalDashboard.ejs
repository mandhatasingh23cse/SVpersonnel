<section class="page-hero">
  <div class="shell page-hero-content">
    <p class="eyebrow">Professional dashboard</p>
    <h1>Manage incoming local booking requests.</h1>
    <p>Your profile, service visibility, and booking demand are now powered by the Supabase database.</p>
  </div>
</section>

<section class="section shell dashboard-shell">
  <%- include("partials/notice") %>

  <div class="dashboard-metrics">
    <article class="metric-card glass-panel" data-reveal>
      <strong><%= dashboardData.summary.totalRequests %></strong>
      <h3>Total requests</h3>
      <p>All booking requests linked to your professional profile.</p>
    </article>
    <article class="metric-card glass-panel" data-reveal>
      <strong><%= dashboardData.summary.confirmedRequests %></strong>
      <h3>Confirmed</h3>
      <p>Requests that are already scheduled or accepted.</p>
    </article>
    <article class="metric-card glass-panel" data-reveal>
      <strong><%= dashboardData.summary.pendingRequests %></strong>
      <h3>Pending</h3>
      <p>Fresh leads waiting for action.</p>
    </article>
  </div>

  <% if (dashboardData.profile) { %>
    <div class="glass-panel dashboard-profile" data-reveal>
      <div class="worker-preview-head">
        <img src="<%= encodeURI(dashboardData.profile.photo) %>" alt="<%= dashboardData.profile.name %>" class="worker-preview-avatar">
        <div>
          <h2><%= dashboardData.profile.name %></h2>
          <p><%= dashboardData.profile.city %><% if (dashboardData.profile.area) { %> | <%= dashboardData.profile.area %><% } %></p>
        </div>
      </div>

      <div class="booking-meta">
        <span><%= dashboardData.profile.experience %> years experience</span>
        <span><%= formatCurrency(dashboardData.profile.startingPrice) %> starting rate</span>
        <span><%= Number(dashboardData.profile.ratings || 0).toFixed(1) %> / 5 rating</span>
      </div>
    </div>

    <% if (!dashboardData.profile.isVerified) { %>
      <div class="glass-panel" style="padding: 2.5rem; border-radius: var(--radius-lg); border: 1px solid var(--line-strong);" data-reveal>
        <p class="card-kicker" style="color: var(--accent);">Identity Verification</p>
        <h2 style="margin-bottom: 0.5rem;">Verify your Professional Account</h2>
        
        <% if (dashboardData.profile.aadhaarPanUrl && dashboardData.profile.livePhotoUrl) { %>
          <div style="margin-top: 1rem; padding: 1.25rem; border-radius: var(--radius-md); background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.15); display: flex; align-items: center; gap: 1rem;">
            <div style="font-size: 1.5rem; color: var(--success);">✓</div>
            <div>
              <span style="font-weight: 700; color: var(--text); display: block;">Verification Documents Submitted</span>
              <span style="font-size: 0.9rem; color: var(--text-muted);">Our administrators are reviewing your Aadhaar/PAN and Live Photo. Your profile will be verified shortly.</span>
            </div>
          </div>
        <% } else { %>
          <p style="color: var(--text-muted); margin-bottom: 1.5rem; font-size: 0.95rem;">
            To receive bookings, please upload your verification documents. An admin will review them to verify your profile.
          </p>

          <form method="POST" action="/professional/upload-verification" enctype="multipart/form-data" class="auth-form" style="display: grid; gap: 1.5rem;">
            <div class="form-row">
              <label class="field-group">
                <span>Aadhaar or PAN Card (PDF or Image)</span>
                <input type="file" name="idDocument" accept="image/*,application/pdf" required>
              </label>
              
              <label class="field-group">
                <span>Live Photo (Take now or Upload)</span>
                <input type="file" name="livePhoto" accept="image/*" capture="user" required>
              </label>
            </div>
            <button type="submit" class="button button-primary" style="justify-self: start;">Submit for Verification</button>
          </form>
        <% } %>
      </div>
    <% } %>
  <% } %>

  <div class="dashboard-list">
    <% if (!dashboardData.bookings.length) { %>
      <div class="empty-state">
        <h3>No booking requests yet.</h3>
        <p>As clients create requests from the live marketplace, they will appear here automatically.</p>
      </div>
    <% } %>

    <% dashboardData.bookings.forEach(function (booking) { %>
      <article class="dashboard-card glass-panel" data-reveal>
        <div class="dashboard-card-top">
          <div class="dashboard-header-copy">
            <p class="card-kicker">Booking <%= booking.bookingCode %></p>
            <h2><%= booking.clientName %></h2>
          </div>
          <span class="result-badge status-badge-<%= booking.status %>"><%= formatStatusLabel(booking.status) %></span>
        </div>

        <div class="dashboard-grid">
          <div class="dashboard-detail">
            <span class="dashboard-label">Service</span>
            <strong><%= booking.serviceName %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Date</span>
            <strong><%= formatShortDate(booking.preferredDate) %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Time</span>
            <strong><%= formatTimeSlot(booking.preferredTimeSlot) %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Budget</span>
            <strong><%= formatCurrency(booking.budgetInr) %></strong>
          </div>
          <div class="dashboard-detail dashboard-detail-wide">
            <span class="dashboard-label">Email</span>
            <strong><%= booking.clientEmail || "Not shared" %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Phone</span>
            <strong><%= (booking.clientPhone && booking.clientPhone.startsWith('G_')) ? 'Not provided' : (booking.clientPhone || 'Not shared') %></strong>
          </div>
          <div class="dashboard-detail dashboard-detail-wide">
            <span class="dashboard-label">Area</span>
            <% 
              let directionsUrl = null;
              if (booking.details && booking.details.includes("[Coordinates:")) {
                const match = booking.details.match(/\[Coordinates:\s*([^,]+),\s*([^\]]+)\]/);
                if (match) {
                  directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${match[1]},${match[2]}`;
                }
              }
              if (!directionsUrl) {
                directionsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(booking.addressArea)}`;
              }
            %>
            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; gap: 1rem; flex-wrap: wrap;">
              <strong><%= booking.addressArea %></strong>
              <a href="<%= directionsUrl %>" target="_blank" rel="noopener noreferrer" style="font-size: 0.85rem; font-weight: 700; color: var(--accent); text-decoration: none; display: flex; align-items: center; gap: 0.25rem;">
                🗺️ Get Directions
              </a>
            </div>
          </div>
        </div>

        <%
          let workStartedAt = null;
          let workCompletedAt = null;
          let totalPayment = null;
          if (booking.details) {
            const startedMatch = booking.details.match(/\[Work Started At:\s*([^\]]+)\]/);
            const completedMatch = booking.details.match(/\[Work Completed At:\s*([^\]]+)\]/);
            const paymentMatch = booking.details.match(/\[Total Payment:\s*(\d+)\]/);
            if (startedMatch) workStartedAt = startedMatch[1];
            if (completedMatch) workCompletedAt = completedMatch[1];
            if (paymentMatch) totalPayment = paymentMatch[1];
          }
        %>

        <% if (booking.details) { %>
          <p class="result-description"><%=- booking.details.replace(/\n/g, '<br>') %></p>
        <% } %>

        <div class="dashboard-actions" style="margin-top: 1rem; width: 100%;">
          <% if (booking.status === "pending") { %>
            <form method="POST" action="/professional/bookings/<%= booking.id %>/status" style="width: 100%;">
              <input type="hidden" name="status" value="confirmed">
              <button type="submit" class="button button-primary button-block">Accept request</button>
            </form>
          <% } %>

          <% if (booking.status === "confirmed" && !workStartedAt) { %>
            <form method="POST" action="/professional/bookings/<%= booking.id %>/start-work" style="display: flex; gap: 0.75rem; align-items: center; width: 100%; flex-wrap: wrap; padding: 1rem; border-radius: var(--radius-md); border: 1px solid var(--line); background: rgba(255, 255, 255, 0.02);">
              <div style="flex: 1; min-width: 200px;">
                <span style="font-size: 0.85rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem; text-align: left;">Enter Client OTP to Start Work</span>
                <input type="text" name="otp" placeholder="6-digit OTP" required style="padding: 8px 12px; font-size: 0.9rem; border-radius: var(--radius-sm); border: 1px solid var(--line); background: var(--bg-card); color: var(--text); width: 100%;">
              </div>
              <button type="submit" class="button button-primary" style="align-self: flex-end; min-height: 40px; padding: 0 20px;">Start Work</button>
            </form>
          <% } %>

          <% if (booking.status === "confirmed" && workStartedAt && !workCompletedAt) { %>
            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; flex-wrap: wrap; padding: 1rem; border-radius: var(--radius-md); border: 1px solid var(--accent-soft); background: rgba(124, 58, 237, 0.04);">
              <div style="text-align: left;">
                <span style="font-weight: 700; color: var(--accent); display: block; margin-bottom: 0.25rem;">⚡ Work In Progress</span>
                <span id="timer-<%= booking.id %>" data-start-time="<%= workStartedAt %>" data-hourly-rate="<%= booking.budgetInr || 500 %>" style="font-family: monospace; font-size: 1.1rem; font-weight: bold; color: var(--text);">00:00:00 (Accrued: ₹0)</span>
              </div>
              <form method="POST" action="/professional/bookings/<%= booking.id %>/complete-work">
                <button type="submit" class="button button-secondary" style="min-height: 40px; padding: 0 20px;">Complete Work</button>
              </form>
            </div>
          <% } %>

          <% if (workCompletedAt) { %>
            <div style="width: 100%; padding: 1rem; border-radius: var(--radius-md); border: 1px solid var(--success); background: rgba(16, 185, 129, 0.04); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
              <div style="text-align: left;">
                <span style="font-size: 0.85rem; color: var(--text-soft); display: block;">Total Payment Calculated</span>
                <strong style="font-size: 1.25rem; color: var(--success);">₹<%= totalPayment %></strong>
              </div>
              <span style="font-size: 0.85rem; color: var(--text-muted);">Duration: <%= Math.max(1, Math.round((new Date(workCompletedAt) - new Date(workStartedAt)) / 60000)) %> mins</span>
            </div>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const timerElements = document.querySelectorAll("[id^='timer-']");

      function updateTimers() {
        timerElements.forEach(el => {
          const startTimeStr = el.dataset.startTime;
          const hourlyRate = Number(el.dataset.hourlyRate || 500);
          if (!startTimeStr) return;

          const start = new Date(startTimeStr).getTime();
          const now = Date.now();
          const diffMs = now - start;

          const hours = Math.floor(diffMs / 3600000);
          const minutes = Math.floor((diffMs % 3600000) / 60000);
          const seconds = Math.floor((diffMs % 60000) / 1000);

          const timeStr = [
            String(hours).padStart(2, '0'),
            String(minutes).padStart(2, '0'),
            String(seconds).padStart(2, '0')
          ].join(':');

          const elapsedHours = diffMs / 3600000;
          let accrued = hourlyRate;
          if (elapsedHours > 1) {
            accrued = Math.round(elapsedHours * hourlyRate);
          } else {
            const elapsedMinutes = diffMs / 60000;
            accrued = Math.max(Math.round(hourlyRate / 2), Math.round((elapsedMinutes / 60) * hourlyRate));
          }

          el.textContent = `${timeStr} (Accrued: ₹${accrued})`;
        });
      }

      setInterval(updateTimers, 1000);
      updateTimers();
    });
  </script>
</section>
