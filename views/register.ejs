<section class="section shell auth-layout">
  <% const selectedSecondarySkills = Array.isArray(registerFormData.secondarySkills)
    ? registerFormData.secondarySkills
    : String(registerFormData.secondarySkills || "")
        .split(",")
        .map(function (skill) { return skill.trim(); })
        .filter(Boolean);
  const selectedSecondarySkill = selectedSecondarySkills[0] || ""; %>

  <div class="glass-panel auth-story" data-reveal>
    <p class="eyebrow">For professionals</p>
    <h1><%= authContent.title %></h1>
    <p><%= authContent.description %></p>

    <ul class="check-list">
      <% authContent.benefits.forEach(function (benefit) { %>
        <li><%= benefit %></li>
      <% }) %>
    </ul>
  </div>

  <div class="glass-panel auth-form-card" data-reveal>
    <p class="card-kicker">Join GigConnect</p>
    <h2>Create your professional profile.</h2>

    <%- include("partials/notice") %>
    <div class="auth-note glass-inset">
      <p><%= bridgeNote %></p>
    </div>

    <form class="auth-form registration-form" action="/register/professional" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <label class="field-group">
          <span>Full name</span>
          <input type="text" id="name" name="fullname" value="<%= registerFormData.name %>" placeholder="Your full name" required>
        </label>

        <label class="field-group">
          <span>Email address</span>
          <input type="email" id="email" name="email" value="<%= registerFormData.email %>" placeholder="name@example.com" required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Phone number</span>
          <input type="tel" id="phone" name="phone" value="<%= registerFormData.phone %>" placeholder="+91 12345 67890" required>
        </label>

        <label class="field-group">
          <span>Primary skill</span>
          <select id="primary-skill" name="primary-skill" required>
            <option value="">Select a platform service</option>
            <% platformServices.forEach(function (service) { %>
              <option value="<%= service.name %>" <%= registerFormData.primarySkill === service.name ? "selected" : "" %>>
                <%= service.name %>
              </option>
            <% }) %>
          </select>
          <small class="field-hint">Choose the main service you want clients to find you for.</small>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Additional skills</span>
          <select id="secondary-skills" name="secondary-skills">
            <option value="">Select an additional service</option>
            <% platformServices.forEach(function (service) { %>
              <option value="<%= service.name %>" <%= selectedSecondarySkill === service.name ? "selected" : "" %>>
                <%= service.name %>
              </option>
            <% }) %>
          </select>
          <small class="field-hint">Optional. Choose one extra platform category you also serve.</small>
        </label>

        <label class="field-group">
          <span>City</span>
          <input type="text" id="city" name="city" value="<%= registerFormData.city %>" placeholder="Gurugram" required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Service area</span>
          <input type="text" id="area" name="area" value="<%= registerFormData.area %>" placeholder="Sector 56, DLF Phase 4" required>
        </label>

        <label class="field-group">
          <span>Experience in years</span>
          <input type="number" id="experience" name="experience" value="<%= registerFormData.experience %>" min="0" max="100" placeholder="6" required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Profile photo (Choose from Gallery)</span>
          <input type="file" id="photo" name="photo" accept="image/*" required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Create password</span>
          <div style="position: relative;">
            <input type="password" id="password" name="password" required style="width: 100%; padding-right: 4.5rem;">
            <button type="button" class="toggle-password-btn" data-toggle-target="password" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); background: none; border: none; font-size: 0.8rem; font-weight: 600; color: var(--color-brand); cursor: pointer;">Show</button>
          </div>
          
          <div class="password-criteria-box" style="margin-top: 0.5rem; font-size: 0.85rem; color: var(--color-ink-light);">
            <p style="margin-bottom: 0.25rem; font-weight: 500;">Password strength requirements:</p>
            <ul style="list-style: none; padding-left: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem;">
              <li class="crit-length" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> At least 8 characters</li>
              <li class="crit-upper" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> Contains an uppercase letter</li>
              <li class="crit-lower" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> Contains a lowercase letter</li>
              <li class="crit-number" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> Contains a number</li>
              <li class="crit-symbol" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> Contains a special character (symbol)</li>
            </ul>
          </div>
        </label>

        <label class="field-group">
          <span>Confirm password</span>
          <div style="position: relative;">
            <input type="password" id="confirm-password" name="confirm-password" required style="width: 100%; padding-right: 4.5rem;">
            <button type="button" class="toggle-password-btn" data-toggle-target="confirm-password" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); background: none; border: none; font-size: 0.8rem; font-weight: 600; color: var(--color-brand); cursor: pointer;">Show</button>
          </div>
        </label>
      </div>

      <label class="field-group">
        <span>Professional summary</span>
        <textarea id="description" name="description" rows="5" placeholder="Describe your work, service quality, and what clients can expect."><%= registerFormData.description %></textarea>
      </label>

      <label class="toggle-row">
        <span>I agree to the <a href="/terms" target="_blank" style="text-decoration: underline; color: var(--color-brand);">Terms of Service</a> and Privacy Policy.</span>
        <input type="checkbox" id="agree-terms" name="agree-terms" required>
      </label>

      <button type="submit" class="button button-primary button-block">Create professional profile</button>
    </form>

    <div style="display: flex; align-items: center; justify-content: center; gap: 1rem; margin-top: 1.5rem; margin-bottom: 1.5rem;">
      <hr style="flex-grow: 1; border: 0; border-top: 1px solid rgba(255,255,255,0.1);">
      <span style="font-size: 0.85rem; color: var(--color-ink-light); font-weight: 500;">or</span>
      <hr style="flex-grow: 1; border: 0; border-top: 1px solid rgba(255,255,255,0.1);">
    </div>

    <a href="/auth/google?role=professional" class="button button-secondary button-block google-auth-btn" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; border-color: rgba(255,255,255,0.25); background: rgba(255,255,255,0.05); color: var(--color-ink); text-decoration: none;">
      <svg width="18" height="18" viewBox="0 0 18 18" style="vertical-align: middle;">
        <path fill="#EA4335" d="M9 3.6c1.62 0 3.06.56 4.21 1.64l3.15-3.15C14.45 1.07 11.97 0 9 0 5.48 0 2.44 2.02.94 4.96l3.69 2.87C5.51 5.33 7.07 3.6 9 3.6z"/>
        <path fill="#4285F4" d="M17.64 9.2c0-.59-.05-1.17-.16-1.73H9v3.29h4.84c-.21 1.12-.84 2.07-1.79 2.7l3.69 2.87c2.16-1.99 3.4-4.92 3.4-8.13z"/>
        <path fill="#FBBC05" d="M4.63 10.79a5.4 5.4 0 0 1 0-3.58L.94 4.34A8.99 8.99 0 0 0 0 9c0 1.67.46 3.23 1.25 4.58l3.38-2.79z"/>
        <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-3.69-2.87c-1.02.68-2.33 1.09-3.79 1.09-2.48 0-4.57-1.68-5.32-3.95L.77 12.96C2.26 15.93 5.37 18 9 18z"/>
      </svg>
      Continue with Google
    </a>

    <p class="auth-switch">Already on the platform? <a href="/professionallogin">Log in</a></p>
  </div>
</section>
