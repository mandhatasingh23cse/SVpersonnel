<section class="section shell auth-layout" style="padding-top: 3rem; padding-bottom: 5rem;">
  <div class="glass-panel auth-story" data-reveal style="max-width: 420px; align-self: flex-start; position: sticky; top: 100px;">
    <p class="eyebrow">Professional Setup Wizard</p>
    <h1>Complete Your SV Onboarding</h1>
    <p>Follow the 4 steps to set up your verified professional listing. Once submitted, our team will verify your details to activate your account.</p>

    <!-- Step Indicators -->
    <div class="steps-progress" style="margin-top: 2rem; display: flex; flex-direction: column; gap: 1.25rem;">
      <div class="step-indicator active" id="indicator-step-1" style="display: flex; align-items: center; gap: 1rem;">
        <span class="step-num" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; background: #a855f7; color: #fff; border: 2px solid #a855f7;">1</span>
        <div style="text-align: left;">
          <h4 style="margin: 0; font-size: 0.92rem; color: #fff;">Service & Location</h4>
          <p style="margin: 0; font-size: 0.75rem; color: #cbd5e1;">Skills, Rates & City</p>
        </div>
      </div>
      <div class="step-indicator" id="indicator-step-2" style="display: flex; align-items: center; gap: 1rem; opacity: 0.5;">
        <span class="step-num" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; background: rgba(255,255,255,0.05); color: #94a3b8; border: 2px solid rgba(255,255,255,0.15);">2</span>
        <div style="text-align: left;">
          <h4 style="margin: 0; font-size: 0.92rem; color: #94a3b8;">Identity & Verification</h4>
          <p style="margin: 0; font-size: 0.75rem; color: #64748b;">Government ID & Selfie</p>
        </div>
      </div>
      <div class="step-indicator" id="indicator-step-3" style="display: flex; align-items: center; gap: 1rem; opacity: 0.5;">
        <span class="step-num" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; background: rgba(255,255,255,0.05); color: #94a3b8; border: 2px solid rgba(255,255,255,0.15);">3</span>
        <div style="text-align: left;">
          <h4 style="margin: 0; font-size: 0.92rem; color: #94a3b8;">Financial & Taxes</h4>
          <p style="margin: 0; font-size: 0.75rem; color: #64748b;">Bank, UPI & PAN</p>
        </div>
      </div>
      <div class="step-indicator" id="indicator-step-4" style="display: flex; align-items: center; gap: 1rem; opacity: 0.5;">
        <span class="step-num" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; background: rgba(255,255,255,0.05); color: #94a3b8; border: 2px solid rgba(255,255,255,0.15);">4</span>
        <div style="text-align: left;">
          <h4 style="margin: 0; font-size: 0.92rem; color: #94a3b8;">Media Portfolio</h4>
          <p style="margin: 0; font-size: 0.75rem; color: #64748b;">Showcase & Certifications</p>
        </div>
      </div>
    </div>
  </div>

  <div class="glass-panel auth-form-card" data-reveal style="flex: 1; max-width: 760px;">
    <form class="auth-form onboarding-form" id="multistep-onboarding-form" action="/professional/onboarding" method="POST" enctype="multipart/form-data">
      
      <!-- STEP 1: SERVICE & LOCATION -->
      <div class="wizard-step" id="step-pane-1">
        <p class="card-kicker">Step 1 of 4 • Service & Location Details</p>
        <h2 style="margin-bottom: 2rem;">Setup skills and service radius</h2>

        <!-- Custom Username -->
        <label class="field-group" style="margin-bottom: 1.5rem;">
          <span>Choose Login Username</span>
          <input type="text" name="username" placeholder="e.g. sunny_carpenter" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
          <small class="field-hint">Must be unique. Clients can use this to view your direct profile URL.</small>
        </label>

        <!-- Availability selector -->
        <div class="field-group glass-inset" style="padding: 1.25rem; border-radius: 14px; background: rgba(15, 23, 42, 0.85); border: 1px solid rgba(56, 189, 248, 0.4); margin-bottom: 1.5rem;">
          <span style="font-size: 1.05rem; font-weight: 800; color: #38bdf8; display: block; margin-bottom: 0.5rem;">Choose Work Availability</span>
          <select name="jobType" id="builder-work-mode" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(0, 0, 0, 0.7); color: #fff; border: 1px solid rgba(56,189,248,0.5); font-weight: 700;">
            <option value="Both / Flexible">⏰ Both / Flexible Shift (Part Time & Full Time)</option>
            <option value="Part Time">⚡ Part Time Only (Daily / Task visits)</option>
            <option value="Full Time">🏢 Full Time Only (Dedicated monthly placement)</option>
          </select>
        </div>

        <!-- Skills builder dropdowns -->
        <div class="field-group glass-inset" style="padding: 1.25rem; border-radius: 14px; background: rgba(15, 23, 42, 0.85); border: 1px solid rgba(168, 85, 247, 0.4); margin-bottom: 1.5rem;">
          <span style="font-size: 1.05rem; font-weight: 800; color: #d8b4fe; display: block; margin-bottom: 0.5rem;">Choose Your Skill Categories</span>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 1rem;">
            <div>
              <label style="font-size: 0.82rem; color: #94a3b8; font-weight: 600; display:block; margin-bottom: 0.35rem;">1. Select Category</label>
              <select id="builder-cat-select" class="form-input" style="width: 100%; padding: 0.7rem 1rem; border-radius: 10px; background: rgba(0,0,0,0.7); color: #fff; border: 1px solid rgba(255,255,255,0.2);">
                <option value="">-- Choose Category --</option>
                <% if (typeof ottCategories !== 'undefined' && ottCategories) { %>
                  <% ottCategories.forEach(function(cat, idx) { %>
                    <option value="<%= idx %>"><%= cat.headerIcon || '🔹' %> <%= cat.title %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
            <div>
              <label style="font-size: 0.82rem; color: #94a3b8; font-weight: 600; display:block; margin-bottom: 0.35rem;">2. Select Sub-Category / Skill</label>
              <select id="builder-subcat-select" disabled class="form-input" style="width: 100%; padding: 0.7rem 1rem; border-radius: 10px; background: rgba(0,0,0,0.7); color: #fff; border: 1px solid rgba(255,255,255,0.2);">
                <option value="">-- First Select Category --</option>
              </select>
            </div>
          </div>
          <button type="button" id="btn-add-skill-card" class="button button-primary" style="padding: 0.75rem 1.5rem; font-weight: 700; border-radius: 10px; background: linear-gradient(135deg, #a855f7, #3b82f6); border: none; cursor: pointer; color: #fff;">
            ➕ Choose This Skill &amp; Set Price Below ›
          </button>
        </div>

        <!-- Selected skills grid -->
        <div class="field-group glass-inset" style="padding: 1.25rem; border-radius: 14px; background: rgba(15, 23, 42, 0.85); border: 1px solid rgba(52, 211, 153, 0.4); margin-bottom: 1.5rem;">
          <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
            <span style="font-size: 1.05rem; font-weight: 800; color: #34d399; display: block;">Set Your Price For Chosen Skills</span>
            <span id="selected-skill-count-badge" style="background: rgba(52,211,153,0.15); color: #34d399; padding: 4px 10px; border-radius: 20px; font-size: 0.78rem; font-weight: 700;">0 Skills Added</span>
          </div>
          <div id="selected-skills-grid" style="display: flex; flex-direction: column; gap: 1rem;">
            <div id="no-skills-placeholder" style="text-align: center; padding: 2rem; border: 1px dashed rgba(255,255,255,0.2); border-radius: 12px; color: #94a3b8;">
              <p style="margin:0; font-size: 0.95rem;">No skills selected yet. Choose a category and sub-category above and click <strong>"➕ Choose This Skill"</strong>!</p>
            </div>
          </div>
          <input type="hidden" name="charges" id="fallback_charges_input" value="500">
        </div>

        <!-- Experience, Languages, Radius & Location Pincode -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; margin-bottom: 1.5rem;">
          <label class="field-group">
            <span>Years of Experience</span>
            <input type="number" name="experience" min="0" max="50" placeholder="e.g. 5" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
          </label>
          <label class="field-group">
            <span>Languages Spoken</span>
            <input type="text" name="languages" placeholder="e.g. Hindi, English" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
          </label>
          <label class="field-group">
            <span>Service Working Radius (KM)</span>
            <input type="number" name="workingRadiusKm" value="15" min="1" max="100" placeholder="e.g. 15" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
          </label>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; margin-bottom: 2rem;">
          <label class="field-group">
            <span>Pincode (Auto-fetch Location)</span>
            <div style="position: relative;">
              <input type="text" name="pincode" id="pro_pincode" maxlength="6" placeholder="e.g. 226006" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
              <span id="pro_pincode_status" style="position: absolute; right: 10px; top: 12px; font-size: 0.8rem; color: #38bdf8;"></span>
            </div>
          </label>
          <label class="field-group">
            <span>Service City</span>
            <input type="text" name="city" id="pro_city" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
          </label>
          <label class="field-group">
            <span>Locality / Area</span>
            <input type="text" name="area" id="pro_area" list="pro-localities" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
            <datalist id="pro-localities"></datalist>
          </label>
        </div>

        <div style="display: flex; justify-content: flex-end; margin-top: 2rem;">
          <button type="button" class="button button-primary" onclick="goToStep(2)" style="padding: 0.9rem 2.2rem; border-radius: 12px; font-weight: 700;">Next Step: Verification Details ›</button>
        </div>
      </div>

      <!-- STEP 2: IDENTITY & VERIFICATION DOCUMENTS -->
      <div class="wizard-step" id="step-pane-2" style="display: none;">
        <p class="card-kicker">Step 2 of 4 • Document Uploads & Selfie</p>
        <h2 style="margin-bottom: 2rem;">Verify your identity for platform safety</h2>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-bottom: 2rem;">
          
          <!-- Government ID PDF/Image File Upload -->
          <label class="field-group glass-inset" style="padding: 1.5rem; border-radius: 14px; border: 1px dashed rgba(255,255,255,0.2); cursor: pointer; text-align: center;">
            <span style="font-size: 2rem; display:block; margin-bottom: 0.5rem;">📄</span>
            <strong style="color: #fff; display:block; margin-bottom: 0.3rem;">Government ID Document</strong>
            <p style="font-size: 0.78rem; color: #94a3b8; margin: 0 0 1.25rem 0;">Upload clear copy of Aadhaar Card, PAN Card, or Driving License (PDF/JPG/PNG max 5MB)</p>
            <input type="file" name="governmentIdDocument" required style="display: none;" onchange="previewFileName(this, 'id-file-name')">
            <span id="id-file-name" style="font-size: 0.85rem; color: #f59e0b; font-weight: 700;">No file selected</span>
          </label>

          <!-- Selfie Image File Upload -->
          <label class="field-group glass-inset" style="padding: 1.5rem; border-radius: 14px; border: 1px dashed rgba(255,255,255,0.2); cursor: pointer; text-align: center;">
            <span style="font-size: 2rem; display:block; margin-bottom: 0.5rem;">📷</span>
            <strong style="color: #fff; display:block; margin-bottom: 0.3rem;">Verification Selfie Image</strong>
            <p style="font-size: 0.78rem; color: #94a3b8; margin: 0 0 1.25rem 0;">Upload a live selfie holding your government photo ID card next to your face (JPG/PNG max 5MB)</p>
            <input type="file" name="liveSelfiePhoto" required style="display: none;" onchange="previewFileName(this, 'selfie-file-name')">
            <span id="selfie-file-name" style="font-size: 0.85rem; color: #f59e0b; font-weight: 700;">No file selected</span>
          </label>

        </div>

        <div style="display: flex; justify-content: space-between; margin-top: 2rem;">
          <button type="button" class="button" onclick="goToStep(1)" style="padding: 0.9rem 2rem; border-radius: 12px; background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.15);">‹ Back</button>
          <button type="button" class="button button-primary" onclick="goToStep(3)" style="padding: 0.9rem 2.2rem; border-radius: 12px; font-weight: 700;">Next Step: Financials & Bank ›</button>
        </div>
      </div>

      <!-- STEP 3: FINANCIALS & TAX DETAILS -->
      <div class="wizard-step" id="step-pane-3" style="display: none;">
        <p class="card-kicker">Step 3 of 4 • Bank Transfer & Tax Setup</p>
        <h2 style="margin-bottom: 2rem;">Configure how you receive payouts</h2>

        <!-- Banking fields -->
        <div class="glass-inset" style="padding: 1.5rem; border-radius: 14px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 2rem;">
          <h3 style="margin-top: 0; margin-bottom: 1.25rem; font-size: 1.1rem; color: #38bdf8;">🏦 Bank Account Details</h3>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; margin-bottom: 1.25rem;">
            <label class="field-group">
              <span>Bank Name</span>
              <input type="text" name="bankName" placeholder="e.g. State Bank of India" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
            </label>
            <label class="field-group">
              <span>Account Number</span>
              <input type="text" name="bankAccountNo" placeholder="e.g. 100092384729" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
            </label>
            <label class="field-group">
              <span>IFSC Code</span>
              <input type="text" name="bankIfsc" placeholder="e.g. SBIN0000125" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
            </label>
          </div>

          <label class="field-group">
            <span>UPI Handle (Optional alternative)</span>
            <input type="text" name="upiHandle" placeholder="e.g. name@okhdfcbank" class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
          </label>
        </div>

        <!-- Tax IDs -->
        <div class="glass-inset" style="padding: 1.5rem; border-radius: 14px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 2rem;">
          <h3 style="margin-top: 0; margin-bottom: 1.25rem; font-size: 1.1rem; color: #a78bfa;">🛡️ Tax Registration IDs</h3>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem;">
            <label class="field-group">
              <span>PAN Card Number</span>
              <input type="text" name="panNumber" maxlength="10" pattern="[A-Za-z]{5}[0-9]{4}[A-Za-z]{1}" title="Strict PAN card format: 5 letters, 4 digits, 1 letter (e.g. ABCDE1234F)" placeholder="e.g. ABCDE1234F" required class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15); text-transform: uppercase; font-weight: bold;">
            </label>
            <label class="field-group">
              <span>GSTIN Number (Optional)</span>
              <input type="text" name="gstNumber" maxlength="15" placeholder="e.g. 09ABCDE1234F1Z5" class="form-input" style="width: 100%; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15);">
            </label>
          </div>
        </div>

        <div style="display: flex; justify-content: space-between; margin-top: 2rem;">
          <button type="button" class="button" onclick="goToStep(2)" style="padding: 0.9rem 2rem; border-radius: 12px; background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.15);">‹ Back</button>
          <button type="button" class="button button-primary" onclick="goToStep(4)" style="padding: 0.9rem 2.2rem; border-radius: 12px; font-weight: 700;">Next Step: Media Portfolio ›</button>
        </div>
      </div>

      <!-- STEP 4: MEDIA PORTFOLIO & CERTIFICATIONS -->
      <div class="wizard-step" id="step-pane-4" style="display: none;">
        <p class="card-kicker">Step 4 of 4 • Showcase Gallery & Certificates</p>
        <h2 style="margin-bottom: 2rem;">Upload items showing your experience</h2>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
          
          <!-- Portfolio Images Upload -->
          <label class="field-group glass-inset" style="padding: 1.5rem; border-radius: 14px; border: 1px dashed rgba(255,255,255,0.2); cursor: pointer; text-align: center;">
            <span style="font-size: 2rem; display:block; margin-bottom: 0.5rem;">🖼️</span>
            <strong style="color: #fff; display:block; margin-bottom: 0.3rem;">Portfolio Images (Multi)</strong>
            <p style="font-size: 0.78rem; color: #94a3b8; margin: 0 0 1.25rem 0;">Upload photo samples of your works/services (Hold Ctrl to select multiple, max 10 files)</p>
            <input type="file" name="portfolioImages" multiple style="display: none;" onchange="previewFileCount(this, 'images-count')">
            <span id="images-count" style="font-size: 0.85rem; color: #f59e0b; font-weight: 700;">0 files selected</span>
          </label>

          <!-- Portfolio Videos Upload -->
          <label class="field-group glass-inset" style="padding: 1.5rem; border-radius: 14px; border: 1px dashed rgba(255,255,255,0.2); cursor: pointer; text-align: center;">
            <span style="font-size: 2rem; display:block; margin-bottom: 0.5rem;">🎥</span>
            <strong style="color: #fff; display:block; margin-bottom: 0.3rem;">Portfolio Videos (Multi)</strong>
            <p style="font-size: 0.78rem; color: #94a3b8; margin: 0 0 1.25rem 0;">Upload video clips showcasing your projects (mp4/webm formats, max 5 files)</p>
            <input type="file" name="portfolioVideos" multiple style="display: none;" onchange="previewFileCount(this, 'videos-count')">
            <span id="videos-count" style="font-size: 0.85rem; color: #f59e0b; font-weight: 700;">0 files selected</span>
          </label>

          <!-- Certifications Upload -->
          <label class="field-group glass-inset" style="padding: 1.5rem; border-radius: 14px; border: 1px dashed rgba(255,255,255,0.2); cursor: pointer; text-align: center; grid-column: 1 / -1;">
            <span style="font-size: 2rem; display:block; margin-bottom: 0.5rem;">📜</span>
            <strong style="color: #fff; display:block; margin-bottom: 0.3rem;">Certificates & Licences</strong>
            <p style="font-size: 0.78rem; color: #94a3b8; margin: 0 0 1.25rem 0;">Upload safety licences, specialized course completion certs, or awards (PDF/Images, max 10 files)</p>
            <input type="file" name="certificates" multiple style="display: none;" onchange="previewFileCount(this, 'certs-count')">
            <span id="certs-count" style="font-size: 0.85rem; color: #f59e0b; font-weight: 700;">0 files selected</span>
          </label>

        </div>

        <div style="display: flex; justify-content: space-between; margin-top: 3rem;">
          <button type="button" class="button" onclick="goToStep(3)" style="padding: 0.9rem 2rem; border-radius: 12px; background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.15);">‹ Back</button>
          <button type="submit" class="button button-primary" style="padding: 1.1rem 3rem; border-radius: 12px; font-weight: 800; background: linear-gradient(135deg, #f59e0b, #d97706); border: none; box-shadow: 0 4px 25px rgba(245,158,11,0.45);">🚀 Complete Onboarding & Submit ›</button>
        </div>
      </div>

    </form>
  </div>
</section>

<script>
  // Simple tab toggle logic for Multi-step Wizard
  function goToStep(stepNum) {
    document.querySelectorAll(".wizard-step").forEach(step => step.style.display = "none");
    document.getElementById("step-pane-" + stepNum).style.display = "block";

    document.querySelectorAll(".step-indicator").forEach((ind, idx) => {
      const currentIdx = idx + 1;
      if (currentIdx === stepNum) {
        ind.style.opacity = "1";
        const badge = ind.querySelector(".step-num");
        badge.style.background = "#a855f7";
        badge.style.color = "#fff";
        badge.style.borderColor = "#a855f7";
        ind.querySelector("h4").style.color = "#fff";
      } else if (currentIdx < stepNum) {
        ind.style.opacity = "0.75";
        const badge = ind.querySelector(".step-num");
        badge.style.background = "#22c55e"; // checkgreen for completed
        badge.style.color = "#fff";
        badge.style.borderColor = "#22c55e";
        badge.textContent = "✓";
      } else {
        ind.style.opacity = "0.5";
        const badge = ind.querySelector(".step-num");
        badge.style.background = "rgba(255,255,255,0.05)";
        badge.style.color = "#94a3b8";
        badge.style.borderColor = "rgba(255,255,255,0.15)";
        badge.textContent = currentIdx;
        ind.querySelector("h4").style.color = "#94a3b8";
      }
    });

    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function previewFileName(inputEl, labelId) {
    const label = document.getElementById(labelId);
    if (inputEl.files && inputEl.files.length > 0) {
      label.textContent = "✅ " + inputEl.files[0].name;
    } else {
      label.textContent = "No file selected";
    }
  }

  function previewFileCount(inputEl, labelId) {
    const label = document.getElementById(labelId);
    if (inputEl.files && inputEl.files.length > 0) {
      label.textContent = "✅ " + inputEl.files.length + " files selected";
    } else {
      label.textContent = "0 files selected";
    }
  }

  // Location Autocomplete Pincode fetch
  document.getElementById("pro_pincode").addEventListener("input", async function() {
    const pin = this.value.trim();
    const statusEl = document.getElementById("pro_pincode_status");
    const datalist = document.getElementById("pro-localities");
    if (!pin || pin.length !== 6 || isNaN(pin)) {
      statusEl.textContent = "";
      return;
    }
    statusEl.textContent = "⌛ Fetching...";
    try {
      const res = await fetch(`https://api.postalpincode.in/pincode/${pin}`);
      const data = await res.json();
      if (data && data[0] && data[0].Status === "Success" && data[0].PostOffice) {
        const pos = data[0].PostOffice;
        const firstPo = pos[0];
        document.getElementById("pro_city").value = firstPo.District || firstPo.Division || firstPo.Block || "";
        datalist.innerHTML = "";
        pos.forEach(po => {
          const opt = document.createElement("option");
          opt.value = po.Name;
          datalist.appendChild(opt);
        });
        if (!document.getElementById("pro_area").value && pos.length > 0) {
          document.getElementById("pro_area").value = pos[0].Name;
        }
        statusEl.textContent = "✅ Valid";
      } else {
        statusEl.textContent = "❌ Not found";
      }
    } catch (e) {
      statusEl.textContent = "";
    }
  });

  // 3-Step Interactive Builder Logic
  const categoriesData = <%- JSON.stringify(typeof ottCategories !== 'undefined' ? ottCategories : []) %>;
  const catSelect = document.getElementById("builder-cat-select");
  const subcatSelect = document.getElementById("builder-subcat-select");
  const workModeSelect = document.getElementById("builder-work-mode");
  const addBtn = document.getElementById("btn-add-skill-card");
  const grid = document.getElementById("selected-skills-grid");
  const placeholder = document.getElementById("no-skills-placeholder");
  const badge = document.getElementById("selected-skill-count-badge");

  let addedSkillsCount = 0;

  if (catSelect && subcatSelect) {
    catSelect.addEventListener("change", function() {
      const catIdx = this.value;
      subcatSelect.innerHTML = '<option value="">-- Choose Sub-Category --</option>';
      if (catIdx !== "" && categoriesData[catIdx] && categoriesData[catIdx].items) {
        categoriesData[catIdx].items.forEach(function(item) {
          const opt = document.createElement("option");
          opt.value = item.name;
          opt.setAttribute("data-cat", categoriesData[catIdx].title);
          opt.textContent = item.name + " (" + item.desc + ")";
          subcatSelect.appendChild(opt);
        });
        subcatSelect.disabled = false;
      } else {
        subcatSelect.disabled = true;
      }
    });

    addBtn.addEventListener("click", function() {
      if (!subcatSelect.value) {
        alert("Please select a Category and Sub-Category first!");
        return;
      }
      const skillName = subcatSelect.value;
      const selectedOpt = subcatSelect.options[subcatSelect.selectedIndex];
      const catName = selectedOpt ? selectedOpt.getAttribute("data-cat") : "General";

      if (document.getElementById("card_skill_" + encodeURIComponent(skillName))) {
        alert("You have already added " + skillName + " to your list below!");
        return;
      }

      if (placeholder) placeholder.style.display = "none";
      addedSkillsCount++;
      badge.textContent = addedSkillsCount + " Skills Added";

      const card = document.createElement("div");
      card.id = "card_skill_" + encodeURIComponent(skillName);
      card.className = "skill-pricing-card glass-inset";
      card.style.cssText = "padding: 1.1rem; border-radius: 12px; background: rgba(15, 23, 42, 0.95); border: 1px solid rgba(168,85,247,0.4); display: flex; flex-direction: column; gap: 0.8rem; position: relative;";
      
      const mode = workModeSelect.value;
      const showPt = (mode === "Both / Flexible" || mode === "Part Time");
      const showFt = (mode === "Both / Flexible" || mode === "Full Time");
      const safeKey = encodeURIComponent(skillName);

      card.innerHTML = `
        <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem;">
          <div>
            <strong style="color: #fff; font-size: 1.05rem;">✨ \${skillName}</strong>
            <span style="font-size: 0.78rem; color: #a855f7; background: rgba(168,85,247,0.15); padding: 2px 8px; border-radius: 6px; margin-left: 8px;">\${catName}</span>
          </div>
          <button type="button" class="btn-remove-skill" style="background: rgba(244,63,94,0.15); color: #fb7185; border: 1px solid rgba(244,63,94,0.3); padding: 4px 10px; border-radius: 6px; cursor: pointer; font-size: 0.8rem;">🗑️ Remove</button>
        </div>
        <input type="hidden" name="skills" value="\${skillName}">
        <input type="hidden" name="subcategorySkills" value="\${skillName}">
        <div class="pricing-rows-box" style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
          <div class="pt-box" style="flex: 1; min-width: 200px; display: \${showPt ? 'flex' : 'none'}; align-items: center; justify-content: space-between; background: rgba(56,189,248,0.1); padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(56,189,248,0.3);">
            <span style="font-size: 0.85rem; color: #38bdf8; font-weight: 700;">⚡ Part-Time Rate (₹ / Day):</span>
            <input type="number" name="customSubRate_\${safeKey}" value="500" min="100" max="100000" class="subrate-pt-input" style="width: 110px; padding: 6px 8px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.3); background: rgba(0,0,0,0.7); color: #fff; font-weight: 700; font-size: 0.95rem; text-align: right;">
          </div>
          <div class="ft-box" style="flex: 1; min-width: 200px; display: \${showFt ? 'flex' : 'none'}; align-items: center; justify-content: space-between; background: rgba(168,85,247,0.1); padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(168,85,247,0.3);">
            <div>
              <span style="font-size: 0.85rem; color: #d8b4fe; font-weight: 700; display:block;">🏢 Full-Time Expected Salary (₹ / Month):</span>
              <small style="font-size: 0.7rem; color: #94a3b8;">* Client pays ₹250 platform fee on full-time hiring</small>
            </div>
            <input type="number" name="customSubFullRate_\${safeKey}" value="25000" min="1000" max="500000" class="subrate-ft-input" style="width: 115px; padding: 6px 8px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.3); background: rgba(0,0,0,0.7); color: #fff; font-weight: 700; font-size: 0.95rem; text-align: right;">
          </div>
        </div>
      `;

      card.querySelector(".btn-remove-skill").addEventListener("click", function() {
        card.remove();
        addedSkillsCount--;
        badge.textContent = addedSkillsCount + " Skills Added";
        if (addedSkillsCount === 0 && placeholder) placeholder.style.display = "block";
      });

      grid.appendChild(card);
    });

    workModeSelect.addEventListener("change", function() {
      const mode = this.value;
      const showPt = (mode === "Both / Flexible" || mode === "Part Time");
      const showFt = (mode === "Both / Flexible" || mode === "Full Time");
      document.querySelectorAll(".pt-box").forEach(el => el.style.display = showPt ? "flex" : "none");
      document.querySelectorAll(".ft-box").forEach(el => el.style.display = showFt ? "flex" : "none");
    });
  }
</script>
