<section class="page-hero">
  <div class="shell page-hero-content">
    <p class="eyebrow">Administration</p>
    <h1>Manage your admin profile.</h1>
    <p>Update your administrative details and account security settings.</p>
  </div>
</section>

<section class="section shell dashboard-shell">
  <%- include("partials/notice") %>

  <div style="display: grid; grid-template-columns: 1fr; gap: 3rem; max-width: 600px; margin: 0 auto;">
    <!-- Profile Information Form -->
    <article class="glass-panel" style="padding: 2.5rem; border-radius: var(--radius-lg);">
      <p class="card-kicker">Admin Details</p>
      <h2 style="margin-bottom: 1.5rem;">Edit Profile Information</h2>

      <form method="POST" action="/admin/profile" class="auth-form">
        <label class="field-group">
          <span>Full name</span>
          <input type="text" name="fullname" value="<%= profile.name %>" required>
        </label>

        <label class="field-group">
          <span>Email Address</span>
          <input type="email" name="email" value="<%= profile.email %>" required>
        </label>

        <div style="margin: 2.5rem 0 1rem 0; border-top: 1px solid var(--line); padding-top: 1.5rem;">
          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Update Password (Optional)</h3>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1rem;">Leave this blank if you do not wish to change your password.</p>
          
          <label class="field-group">
            <span>New Password</span>
            <input type="password" name="newPassword" placeholder="Minimum 6 characters">
          </label>
        </div>

        <button type="submit" class="button button-primary" style="margin-top: 1rem;">Save &amp; Update Profile</button>
      </form>
    </article>
  </div>
</section>
