<section class="section shell auth-layout">
  <div class="glass-panel auth-story" data-reveal>
    <p class="eyebrow">For agencies & franchises</p>
    <h1>Register your Service Agency / Franchise</h1>
    <p>Partner with SV Personnels to onboard, verify, and manage multiple service professionals. Receive booking requests and earn revenue with automatic billing splits.</p>

    <ul class="check-list">
      <li>Register and create verified professional accounts instantly under your agency</li>
      <li>Auto-verification for your professionals (skip manual verification queues)</li>
      <li>Centralized partner earnings wallet & rolling weekly withdrawals</li>
    </ul>
  </div>

  <div class="glass-panel auth-form-card" data-reveal>
    <p class="card-kicker">Franchise sign up</p>
    <h2>Create your partner account.</h2>

    <%- include("partials/notice") %>

    <form class="auth-form registration-form" action="/register/partner" method="POST">
      <div class="form-row">
        <label class="field-group">
          <span>Full name</span>
          <input type="text" id="fullname" name="fullname" value="<%= formData && formData.fullname ? formData.fullname : '' %>" placeholder="Authorized Representative" required>
        </label>

        <label class="field-group">
          <span>Business / Agency name</span>
          <input type="text" id="businessName" name="businessName" value="<%= formData && formData.businessName ? formData.businessName : '' %>" placeholder="e.g. SV Cleaning Services" required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Email address</span>
          <input type="email" id="email" name="email" value="<%= formData && formData.email ? formData.email : '' %>" placeholder="agency@example.com" required>
        </label>

        <label class="field-group">
          <span>Phone number</span>
          <input type="tel" id="phone" name="phone" value="<%= formData && formData.phone ? formData.phone : '' %>" placeholder="+91 12345 67890" required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Choose username</span>
          <input type="text" id="username" name="username" value="<%= formData && formData.username ? formData.username : '' %>" placeholder="unique_agency_username" required>
        </label>

        <label class="field-group">
          <span>City</span>
          <input type="text" id="city" name="city" value="<%= formData && formData.city ? formData.city : '' %>" placeholder="e.g. New Delhi" required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Create password</span>
          <div style="position: relative;">
            <input type="password" id="password" name="password" required style="width: 100%; padding-right: 4.5rem;">
            <button type="button" class="toggle-password-btn" data-toggle-target="password" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); background: none; border: none; font-size: 0.8rem; font-weight: 600; color: var(--color-brand); cursor: pointer;">Show</button>
          </div>
          
          <div class="password-criteria-box" style="margin-top: 0.5rem; font-size: 0.85rem; color: var(--color-ink-light);">
            <p style="margin-bottom: 0.25rem; font-weight: 500;">Password strength requirements:</p>
            <ul style="list-style: none; padding-left: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem;">
              <li class="crit-length" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> At least 8 characters</li>
              <li class="crit-upper" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> Contains an uppercase letter</li>
              <li class="crit-lower" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> Contains a lowercase letter</li>
              <li class="crit-number" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> Contains a number</li>
              <li class="crit-symbol" style="display: flex; align-items: center; gap: 0.5rem;"><span class="bullet" style="color: var(--color-ink-light); font-weight: bold;">○</span> Contains a special character (symbol)</li>
            </ul>
          </div>
        </label>

        <label class="field-group">
          <span>Confirm password</span>
          <div style="position: relative;">
            <input type="password" id="confirm-password" name="confirmPassword" required style="width: 100%; padding-right: 4.5rem;">
            <button type="button" class="toggle-password-btn" data-toggle-target="confirm-password" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); background: none; border: none; font-size: 0.8rem; font-weight: 600; color: var(--color-brand); cursor: pointer;">Show</button>
          </div>
        </label>
      </div>

      <label class="toggle-row">
        <span>I agree to the <a href="/terms" target="_blank" style="text-decoration: underline; color: var(--color-brand);">SV Partner franchise agreement & Terms</a> and Privacy Policy.</span>
        <input type="checkbox" id="agree-terms" name="agreeTerms" required>
      </label>

      <button type="submit" class="button button-primary button-block">Create partner account</button>
    </form>

    <p class="auth-switch">Already have a partner account? <a href="/login">Log in</a></p>
  </div>
</section>
