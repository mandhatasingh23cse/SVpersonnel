<section class="page-hero">
  <div class="shell page-hero-content">
    <p class="eyebrow">Book service</p>
    <h1><%= professional ? `Book ${professional.name}` : "Request a service" %></h1>
    <p>Share your preferred time, area, and budget in rupees to create a live booking request.</p>
  </div>
</section>

<section class="section shell booking-layout">
  <div class="glass-panel booking-summary" data-reveal>
    <p class="card-kicker">Professional summary</p>

    <% if (professional) { %>
      <div class="booking-pro">
        <img src="<%= encodeURI(professional.photo) %>" alt="<%= professional.name %>" class="worker-preview-avatar">
        <div>
          <h2><%= professional.name %></h2>
          <p><%= professional.city %><% if (professional.area) { %> | <%= professional.area %><% } %></p>
        </div>
      </div>

      <div class="booking-badges">
        <span class="result-badge is-rating"><%= Number(professional.ratings || 0).toFixed(1) %> / 5 rating</span>
        <% if (professional.isVerified) { %>
          <span class="result-badge is-verified">Verified professional</span>
        <% } %>
      </div>

      <div class="booking-meta">
        <span><%= professional.experience %> years experience</span>
        <span><%= professional.distance %> km away</span>
        <span>Starts at <%= formatCurrency(professional.startingPrice) %></span>
      </div>

      <div class="result-skills">
        <% professional.skills.forEach(function (skill) { %>
          <span class="skill-tag"><%= skill %></span>
        <% }) %>
      </div>

      <p class="result-description"><%= professional.description %></p>
    <% } else { %>
      <p class="result-description">Choose a professional from the search results to start a booking.</p>
    <% } %>
  </div>

  <div class="glass-panel booking-form-card" data-reveal>
    <p class="card-kicker">Create request</p>
    <h2>Send a booking request</h2>

    <%- include("partials/notice") %>

    <form class="auth-form" method="POST" action="<%= professional ? `/book-service/${professional.id}` : '#' %>">
      <div class="form-row">
        <label class="field-group">
          <span>Full name</span>
          <input type="text" name="fullName" value="<%= formData.fullName %>" readonly required>
        </label>

        <label class="field-group">
          <span>Email</span>
          <input type="email" name="email" value="<%= formData.email %>" readonly required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Phone number</span>
          <input type="tel" name="phone" value="<%= formData.phone %>" readonly required>
        </label>

        <label class="field-group">
          <span>Service</span>
          <select name="serviceId" required>
            <% serviceOptions.forEach(function (service) { %>
              <option value="<%= service.id %>" <%= String(formData.serviceId) === String(service.id) ? "selected" : "" %>>
                <%= service.name %> | <%= formatCurrency(service.priceInr) %>
              </option>
            <% }) %>
          </select>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group">
          <span>Preferred date</span>
          <input type="date" name="preferredDate" value="<%= formData.preferredDate %>" required>
        </label>

        <label class="field-group">
          <span>Time slot</span>
          <input type="text" name="preferredTimeSlot" value="<%= formData.preferredTimeSlot %>" placeholder="10:00 AM - 12:00 PM" required>
        </label>
      </div>

      <div class="form-row">
        <label class="field-group" style="position: relative; flex: 1;">
          <span style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
            <span>Area / address</span>
            <button type="button" id="btn-fetch-location" style="background: none; border: none; color: var(--accent); cursor: pointer; font-size: 0.8rem; font-weight: 700; display: flex; align-items: center; gap: 0.25rem; padding: 0;">
              📍 Use Current Location
            </button>
          </span>
          <div style="position: relative; width: 100%;">
            <input type="text" id="addressAreaInput" name="addressArea" value="<%= formData.addressArea %>" placeholder="Type to search (e.g. Kaptanganj, Kushinagar)" autocomplete="off" required style="width: 100%;">
            <div id="address-suggestions" style="position: absolute; top: 100%; left: 0; right: 0; background: #0f172a; border: 1px solid var(--line); border-radius: var(--radius-sm); max-height: 200px; overflow-y: auto; z-index: 100; display: none; box-shadow: var(--shadow-lg);"></div>
          </div>
          <span style="font-size: 0.75rem; color: var(--text-soft); margin-top: 0.25rem; display: block;">
            💡 Type your city/area to search, or use the auto-locator. You can also edit it manually.
          </span>
          <input type="hidden" id="latitudeInput" name="latitude" value="">
          <input type="hidden" id="longitudeInput" name="longitude" value="">
        </label>

        <label class="field-group">
          <span>Budget in rupees</span>
          <input type="number" name="budget" value="<%= formData.budget %>" min="100" max="100000" required>
        </label>
      </div>

      <!-- Payment Method Selection -->
      <div style="margin: 2rem 0 1.5rem 0; border-top: 1px solid var(--line); padding-top: 1.5rem;">
        <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">Payment Method</h3>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.25rem;">Choose how you want to pay the professional:</p>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
          <label style="display: flex; flex-direction: column; gap: 0.5rem; padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--line); background: rgba(255, 255, 255, 0.02); cursor: pointer;">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <input type="radio" name="paymentMethod" value="cod" checked style="width: auto;">
              <strong style="color: var(--text);">Pay After Service (COD)</strong>
            </div>
            <span style="font-size: 0.85rem; color: var(--text-muted);">Pay directly via Cash/UPI after the work is completed.</span>
          </label>
          
          <label style="display: flex; flex-direction: column; gap: 0.5rem; padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--line); background: rgba(255, 255, 255, 0.02); cursor: pointer;">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <input type="radio" name="paymentMethod" value="online" style="width: auto;">
              <strong style="color: var(--text);">Online Payment</strong>
            </div>
            <span style="font-size: 0.85rem; color: var(--text-muted);">Secure digital payment via UPI, Credit/Debit Cards, or NetBanking.</span>
          </label>
        </div>

        <!-- Simulated UPI QR Code or Card Input (Shown only when 'online' is selected) -->
        <div id="online-payment-details" style="display: none; padding: 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--accent-soft); background: rgba(124, 58, 237, 0.04); margin-bottom: 1.5rem; text-align: center;">
          <h4 style="margin: 0 0 0.5rem 0; color: var(--accent);">Simulated Secure Payment</h4>
          <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">Scan this QR code with any UPI app (GPay, PhonePe, Paytm) to pay securely:</p>
          <div style="background: white; padding: 10px; display: inline-block; border-radius: var(--radius-sm); margin-bottom: 1rem;">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=upi://pay?pa=gigconnect@sbi%26pn=SV%20Personnels%26mc=0000%26tr=GC12345%26tn=Booking%20Payment" alt="UPI QR Code" style="display: block; width: 150px; height: 150px;">
          </div>
          <p style="font-size: 0.8rem; color: var(--text-soft); margin: 0;">UPI ID: <strong style="color: var(--text);">gigconnect@sbi</strong></p>
        </div>
      </div>

      <label class="field-group">
        <span>Job details</span>
        <textarea name="details" rows="5" placeholder="What needs to be done?"><%= formData.details %></textarea>
      </label>

      <button type="submit" class="button button-primary button-block">Create booking request</button>
    </form>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const paymentRadios = document.querySelectorAll('input[name="paymentMethod"]');
    const onlineDetails = document.getElementById('online-payment-details');

    paymentRadios.forEach(radio => {
      radio.addEventListener('change', (e) => {
        if (e.target.value === 'online') {
          onlineDetails.style.display = 'block';
        } else {
          onlineDetails.style.display = 'none';
        }
      });
    });

    const locationBtn = document.getElementById("btn-fetch-location");
    const addressInput = document.getElementById("addressAreaInput");
    const latInput = document.getElementById("latitudeInput");
    const lngInput = document.getElementById("longitudeInput");

    function fetchIpLocation() {
      locationBtn.innerHTML = "⌛ IP Fetching...";
      locationBtn.disabled = true;
      fetch("https://ipapi.co/json/")
        .then(res => res.json())
        .then(data => {
          if (data && data.city) {
            const fullAddress = `${data.city}, ${data.region || ""}, ${data.country_name || ""}`;
            addressInput.value = fullAddress;
            latInput.value = data.latitude || "";
            lngInput.value = data.longitude || "";
            locationBtn.innerHTML = "📍 Location Saved (IP)";
            locationBtn.disabled = false;
          } else {
            throw new Error("Invalid IP location data");
          }
        })
        .catch(err => {
          console.error(err);
          alert("Unable to retrieve location automatically (HTTPS is required for GPS on mobile). Please type it manually.");
          locationBtn.innerHTML = "📍 Use Current Location";
          locationBtn.disabled = false;
        });
    }

    locationBtn.addEventListener("click", () => {
      if (!navigator.geolocation) {
        fetchIpLocation();
        return;
      }

      locationBtn.innerHTML = "⌛ Fetching...";
      locationBtn.disabled = true;

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const lat = position.coords.latitude;
          const lng = position.coords.longitude;
          latInput.value = lat;
          lngInput.value = lng;

          // Reverse geocode via OpenStreetMap Nominatim
          fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
            .then(res => res.json())
            .then(data => {
              if (data && data.display_name) {
                addressInput.value = data.display_name;
              } else {
                addressInput.value = `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
              }
              locationBtn.innerHTML = "📍 Location Saved";
              locationBtn.disabled = false;
            })
            .catch(err => {
              console.error(err);
              addressInput.value = `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
              locationBtn.innerHTML = "📍 Location Saved";
              locationBtn.disabled = false;
            });
        },
        (error) => {
          console.error(error);
          fetchIpLocation();
        },
        {
          enableHighAccuracy: true,
          timeout: 10000,
          maximumAge: 0
        }
      );
    });

    // Address Autocomplete Logic
    const suggestionsContainer = document.getElementById("address-suggestions");
    let debounceTimeout;

    addressInput.addEventListener("input", () => {
      clearTimeout(debounceTimeout);
      const query = addressInput.value.trim();
      if (query.length < 3) {
        suggestionsContainer.style.display = "none";
        return;
      }

      debounceTimeout = setTimeout(() => {
        fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&countrycodes=in&limit=5`)
          .then(res => res.json())
          .then(data => {
            if (data && data.length > 0) {
              suggestionsContainer.innerHTML = data.map(item => `
                <div class="suggestion-item" data-lat="${item.lat}" data-lon="${item.lon}" data-name="${item.display_name}" style="padding: 10px 12px; cursor: pointer; border-bottom: 1px solid var(--line); font-size: 0.85rem; color: #f8fafc; text-align: left; transition: background 0.2s;">
                  ${item.display_name}
                </div>
              `).join("");
              suggestionsContainer.style.display = "block";

              // Add click listeners to items
              suggestionsContainer.querySelectorAll(".suggestion-item").forEach(item => {
                item.addEventListener("click", () => {
                  addressInput.value = item.dataset.name;
                  latInput.value = item.dataset.lat;
                  lngInput.value = item.dataset.lon;
                  suggestionsContainer.style.display = "none";
                });
              });
            } else {
              suggestionsContainer.style.display = "none";
            }
          })
          .catch(err => console.error(err));
      }, 300);
    });

    // Hover styling
    suggestionsContainer.addEventListener("mouseover", (e) => {
      const target = e.target.closest(".suggestion-item");
      if (target) target.style.background = "rgba(255, 255, 255, 0.08)";
    });
    suggestionsContainer.addEventListener("mouseout", (e) => {
      const target = e.target.closest(".suggestion-item");
      if (target) target.style.background = "none";
    });

    // Close suggestions when clicking outside
    document.addEventListener("click", (e) => {
      if (e.target !== addressInput && e.target !== suggestionsContainer) {
        suggestionsContainer.style.display = "none";
      }
    });
  });
</script>
