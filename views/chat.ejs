<section class="section shell" style="max-width: 1200px; margin: 2rem auto; padding: 0 1.25rem;">
  <div class="glass-panel" style="display: grid; grid-template-columns: 320px 1fr; height: 75vh; border-radius: 24px; overflow: hidden; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 20px 50px rgba(0,0,0,0.6);">
    
    <!-- Contacts Sidebar -->
    <div style="border-right: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; background: rgba(30, 41, 59, 0.3);">
      <div style="padding: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08);">
        <h2 style="margin: 0; font-size: 1.35rem; color: #fff; font-weight: 800;">💬 Messages</h2>
      </div>

      <div style="flex: 1; overflow-y: auto; padding: 0.75rem 0.5rem; display: flex; flex-direction: column; gap: 0.35rem;">
        <% if (contacts.length === 0) { %>
          <p style="text-align: center; padding: 2rem; color: #64748b; font-size: 0.9rem;">No active chats yet. Connect with professionals or clients to start messaging.</p>
        <% } else { %>
          <% contacts.forEach(contact => { %>
            <% const unreadKey = `${contact.role}_${contact.id}`; %>
            <% const unreadCount = unreadCounts && unreadCounts[unreadKey] ? unreadCounts[unreadKey] : 0; %>
            <% const isActive = activeContact && activeContact.id === contact.id && activeContact.role === contact.role; %>
            <a href="/chat/<%= contact.role %>/<%= contact.id %>" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.9rem 1rem; border-radius: 12px; text-decoration: none; transition: background 0.2s; background: <%= isActive ? 'rgba(255,255,255,0.05)' : 'transparent' %>; border: 1px solid <%= isActive ? 'rgba(255,255,255,0.1)' : 'transparent' %>;" class="contact-item">
              <div style="position: relative;">
                <img src="<%= contact.photo %>" alt="<%= contact.name %>" style="width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 2px solid <%= isActive ? '#a855f7' : 'rgba(255,255,255,0.1)' %>;">
                <span class="online-indicator" id="online-<%= contact.role %>-<%= contact.id %>" style="position: absolute; bottom: 2px; right: 2px; width: 10px; height: 10px; border-radius: 50%; background: #64748b; border: 2px solid #0f172a;"></span>
              </div>
              <div style="flex: 1; min-width: 0;">
                <h4 style="margin: 0 0 0.2rem 0; font-size: 0.95rem; color: #fff; text-overflow: ellipsis; overflow: hidden; white-space: nowrap; font-weight: <%= unreadCount > 0 ? '800' : '600' %>;"><%= contact.name %></h4>
                <p style="margin: 0; font-size: 0.75rem; color: #94a3b8; text-transform: uppercase;"><%= contact.role %></p>
              </div>
              <% if (unreadCount > 0) { %>
                <span style="background: #ef4444; color: #fff; font-size: 0.75rem; font-weight: 800; padding: 3px 8px; border-radius: 20px; min-width: 20px; text-align: center;"><%= unreadCount %></span>
              <% } %>
            </a>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- Active Chat Board -->
    <div style="display: flex; flex-direction: column; height: 100%; background: rgba(15, 23, 42, 0.4);">
      <% if (!activeContact) { %>
        <!-- Empty State -->
        <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 3rem; color: #64748b;">
          <span style="font-size: 4rem; display:block; margin-bottom: 1rem;">💬</span>
          <h3 style="color: #fff; margin-bottom: 0.5rem; font-weight: 700;">Your Secure Chatroom</h3>
          <p style="max-width: 360px; font-size: 0.9rem;">Select a contact from the sidebar or click "Chat Now" on active bookings to message securely in realtime.</p>
        </div>
      <% } else { %>
        <!-- Active Chat Header -->
        <div style="padding: 1.25rem 2rem; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between; background: rgba(30, 41, 59, 0.2);">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <img src="<%= activeContact.photo %>" alt="<%= activeContact.name %>" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
            <div>
              <h3 style="margin: 0; font-size: 1.05rem; color: #fff; font-weight: 700;"><%= activeContact.name %></h3>
              <p id="chat-header-status" style="margin: 0; font-size: 0.78rem; color: #94a3b8;">🔒 Encrypted Connection</p>
            </div>
          </div>
        </div>

        <!-- Messages Board -->
        <div id="messages-container" style="flex: 1; overflow-y: auto; padding: 2rem; display: flex; flex-direction: column; gap: 1rem;">
          <% chatHistory.forEach(msg => { %>
            <% const isMine = msg.sender_role === myRole && Number(msg.sender_id) === Number(myId); %>
            <div style="display: flex; justify-content: <%= isMine ? 'flex-end' : 'flex-start' %>;">
              <div class="message-bubble" style="max-width: 60%; padding: 0.9rem 1.25rem; border-radius: 18px; background: <%= isMine ? 'linear-gradient(135deg, #a855f7, #3b82f6)' : 'rgba(255,255,255,0.05)' %>; color: #fff; border: 1px solid <%= isMine ? 'transparent' : 'rgba(255,255,255,0.1)' %>; border-bottom-right-radius: <%= isMine ? '2px' : '18px' %>; border-bottom-left-radius: <%= isMine ? '18px' : '2px' %>; box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
                
                <% if (msg.image_url) { %>
                  <img src="<%= msg.image_url %>" alt="Sent image" style="max-width: 100%; border-radius: 8px; margin-bottom: 0.5rem; display: block; border: 1px solid rgba(255,255,255,0.1);">
                <% } %>
                
                <p style="margin: 0; font-size: 0.95rem; line-height: 1.45; word-break: break-word;"><%= msg.message %></p>
                
                <div style="text-align: right; margin-top: 0.35rem; font-size: 0.72rem; color: <%= isMine ? 'rgba(255,255,255,0.7)' : '#64748b' %>; display: flex; align-items: center; justify-content: flex-end; gap: 4px;">
                  <span><%= new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
                  <% if (isMine) { %>
                    <span><%= msg.is_read ? '✓✓' : '✓' %></span>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
          <div id="typing-indicator" style="display: none; justify-content: flex-start;">
            <div style="padding: 0.6rem 1rem; border-radius: 12px; background: rgba(255,255,255,0.03); color: #94a3b8; font-size: 0.8rem; display: flex; align-items: center; gap: 0.35rem; border: 1px solid rgba(255,255,255,0.05);">
              <span class="typing-dot" style="width: 6px; height: 6px; border-radius: 50%; background: #a855f7; display:inline-block; animation: typing-bounce 1.4s infinite both;"></span>
              <span class="typing-dot" style="width: 6px; height: 6px; border-radius: 50%; background: #a855f7; display:inline-block; animation: typing-bounce 1.4s infinite both; animation-delay: 0.2s;"></span>
              <span class="typing-dot" style="width: 6px; height: 6px; border-radius: 50%; background: #a855f7; display:inline-block; animation: typing-bounce 1.4s infinite both; animation-delay: 0.4s;"></span>
              <span style="margin-left: 0.25rem;"><%= activeContact.name %> is typing...</span>
            </div>
          </div>
        </div>

        <!-- Chat Input Bar -->
        <div style="padding: 1.25rem 2rem; border-top: 1px solid rgba(255,255,255,0.08); background: rgba(30, 41, 59, 0.25);">
          <div id="image-preview-bar" style="display: none; align-items: center; gap: 0.75rem; padding: 0.5rem; background: rgba(0,0,0,0.4); border-radius: 10px; margin-bottom: 0.75rem; border: 1px solid rgba(255,255,255,0.1);">
            <img id="preview-uploaded-img" src="" alt="Preview" style="height: 50px; border-radius: 6px;">
            <span style="font-size: 0.85rem; color: #fff; flex: 1;">Ready to send photo</span>
            <button type="button" onclick="cancelImagePreview()" style="background: none; border: none; color: #ef4444; cursor: pointer; font-size: 1.1rem; font-weight: 800;">✕</button>
          </div>

          <form id="chat-input-form" style="display: flex; gap: 1rem; align-items: center;">
            <!-- File attachment button -->
            <button type="button" onclick="triggerFileInput()" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; width: 46px; height: 46px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; cursor: pointer; color: #cbd5e1; transition: background 0.2s;">
              📷
            </button>
            <input type="file" id="chat-image-input" style="display: none;" onchange="handleImageUpload(this)">

            <input type="text" id="chat-text-input" placeholder="Type a message secure and live..." required autocomplete="off" style="flex: 1; padding: 0.8rem 1.25rem; border-radius: 12px; background: rgba(15, 23, 42, 0.8); color: #fff; border: 1px solid rgba(255,255,255,0.15); outline: none;">
            
            <button type="submit" style="background: linear-gradient(135deg, #a855f7, #3b82f6); border: none; color: #fff; padding: 0.8rem 1.75rem; border-radius: 12px; font-weight: 700; cursor: pointer; box-shadow: 0 4px 15px rgba(168,85,247,0.3);">
              Send ›
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- CSS bouncing dots animation keyframes -->
<style>
  @keyframes typing-bounce {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1); }
  }
  .typing-dot {
    animation: typing-bounce 1.4s infinite ease-in-out both;
  }
</style>

<% if (activeContact) { %>
  <!-- Load Socket.io Client -->
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();

    const myRole = "<%= myRole %>";
    const myId = Number("<%= myId %>");
    const targetRole = "<%= activeContact.role %>";
    const targetId = Number("<%= activeContact.id %>");

    const myRoom = `${myRole}_${myId}`;
    const targetRoom = `${targetRole}_${targetId}`;

    let uploadedImageUrl = null;

    // Join room
    socket.emit("join", myRoom);

    // Scroll to bottom
    const msgContainer = document.getElementById("messages-container");
    if (msgContainer) {
      msgContainer.scrollTop = msgContainer.scrollHeight;
    }

    // Submit handler
    const form = document.getElementById("chat-input-form");
    const txtInput = document.getElementById("chat-text-input");

    form.addEventListener("submit", function(e) {
      e.preventDefault();
      const messageText = txtInput.value.trim();
      if (!messageText && !uploadedImageUrl) return;

      socket.emit("send_message", {
        senderRole: myRole,
        senderId: myId,
        receiverRole: targetRole,
        receiverId: targetId,
        message: messageText,
        imageUrl: uploadedImageUrl
      });

      txtInput.value = "";
      cancelImagePreview();
      socket.emit("typing", { senderRole: myRole, senderId: myId, receiverRole: targetRole, receiverId: targetId, isTyping: false });
    });

    // Listen to incoming messages
    socket.on("new_message", function(msg) {
      // Check if message belongs to current active conversation
      const isMine = msg.sender_role === myRole && Number(msg.sender_id) === myId;
      const isFromTarget = msg.sender_role === targetRole && Number(msg.sender_id) === targetId;

      if (isMine || isFromTarget) {
        const bubble = document.createElement("div");
        bubble.style.display = "flex";
        bubble.style.justifyContent = isMine ? "flex-end" : "flex-start";

        const formattedTime = new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        let mediaHtml = "";
        if (msg.image_url) {
          mediaHtml = `<img src="${msg.image_url}" alt="Sent image" style="max-width: 100%; border-radius: 8px; margin-bottom: 0.5rem; display: block; border: 1px solid rgba(255,255,255,0.1);">`;
        }

        bubble.innerHTML = `
          <div class="message-bubble" style="max-width: 60%; padding: 0.9rem 1.25rem; border-radius: 18px; background: ${isMine ? 'linear-gradient(135deg, #a855f7, #3b82f6)' : 'rgba(255,255,255,0.05)'}; color: #fff; border: 1px solid ${isMine ? 'transparent' : 'rgba(255,255,255,0.1)'}; border-bottom-right-radius: ${isMine ? '2px' : '18px'}; border-bottom-left-radius: ${isMine ? '18px' : '2px'}; box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
            ${mediaHtml}
            <p style="margin: 0; font-size: 0.95rem; line-height: 1.45; word-break: break-word;">${msg.message}</p>
            <div style="text-align: right; margin-top: 0.35rem; font-size: 0.72rem; color: ${isMine ? 'rgba(255,255,255,0.7)' : '#64748b'}; display: flex; align-items: center; justify-content: flex-end; gap: 4px;">
              <span>${formattedTime}</span>
              ${isMine ? '<span>✓</span>' : ''}
            </div>
          </div>
        `;

        const typingIndicator = document.getElementById("typing-indicator");
        msgContainer.insertBefore(bubble, typingIndicator);
        msgContainer.scrollTop = msgContainer.scrollHeight;
      }
    });

    // Handle typing events
    let typingTimeout = null;
    txtInput.addEventListener("input", function() {
      socket.emit("typing", { senderRole: myRole, senderId: myId, receiverRole: targetRole, receiverId: targetId, isTyping: true });
      
      clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => {
        socket.emit("typing", { senderRole: myRole, senderId: myId, receiverRole: targetRole, receiverId: targetId, isTyping: false });
      }, 3000);
    });

    socket.on("typing_status", function(data) {
      if (data.senderRole === targetRole && Number(data.senderId) === targetId) {
        const indicator = document.getElementById("typing-indicator");
        if (data.isTyping) {
          indicator.style.display = "flex";
          msgContainer.scrollTop = msgContainer.scrollHeight;
        } else {
          indicator.style.display = "none";
        }
      }
    });

    // Image Upload triggers
    function triggerFileInput() {
      document.getElementById("chat-image-input").click();
    }

    async function handleImageUpload(inputEl) {
      if (!inputEl.files || inputEl.files.length === 0) return;
      const file = inputEl.files[0];
      
      const formData = new FormData();
      formData.append("file", file);

      const previewBar = document.getElementById("image-preview-bar");
      const previewImg = document.getElementById("preview-uploaded-img");

      try {
        const res = await fetch("/chat/upload", {
          method: "POST",
          body: formData
        });
        const data = await res.json();
        if (data.success && data.url) {
          uploadedImageUrl = data.url;
          previewImg.src = data.url;
          previewBar.style.display = "flex";
        } else {
          alert("Image upload failed: " + (data.error || "Unknown error"));
        }
      } catch (err) {
        alert("Upload error: " + err.message);
      }
    }

    function cancelImagePreview() {
      uploadedImageUrl = null;
      document.getElementById("image-preview-bar").style.display = "none";
      document.getElementById("chat-image-input").value = "";
    }
  </script>
<% } %>
