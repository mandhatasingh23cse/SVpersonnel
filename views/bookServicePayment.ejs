<section class="page-hero">
  <div class="shell page-hero-content">
    <p class="eyebrow">Step 2 of 2: Payment & Confirmation</p>
    <h1>Select Payment Method</h1>
    <p>Choose whether to pay securely online via PayU right now or settle directly with your professional on completion.</p>
  </div>
</section>

<section class="section shell" style="max-width: 980px; margin: 0 auto; width: 100%; box-sizing: border-box; padding: 2rem 1rem;">
  <div class="glass-panel" style="width: 100%; box-sizing: border-box; padding: 2.5rem; border-radius: 28px; border: 1px solid rgba(255,255,255,0.16); background: rgba(15, 23, 42, 0.85); box-shadow: 0 20px 60px rgba(0,0,0,0.6);" data-reveal>
    
    <!-- Booking Summary Header -->
    <div style="margin-bottom: 2.25rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 1.5rem;">
      <span style="display: inline-block; background: rgba(56, 189, 248, 0.15); color: #38bdf8; padding: 4px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.6rem;">Booking & Address Summary</span>
      
      <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1.5rem; padding: 1.5rem; background: rgba(255,255,255,0.03); border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); margin-top: 0.75rem;">
        <div style="display: flex; align-items: center; gap: 1.25rem;">
          <img src="<%= encodeURI(professional.photo || '/images/default-avatar.png') %>" alt="<%= professional.name %>" style="width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 3px solid #38bdf8; box-shadow: 0 4px 16px rgba(56, 189, 248, 0.3);">
          <div>
            <h3 style="margin: 0 0 0.3rem 0; color: #fff; font-size: 1.35rem; font-weight: 800;"><%= professional.name %></h3>
            <p style="margin: 0; color: #94a3b8; font-size: 0.92rem; font-weight: 600;">🛠️ <%= professional ? (professional.skills.join(', ') || 'Service') : 'Service' %></p>
          </div>
        </div>
        
        <div style="text-align: right;">
          <span style="display: inline-block; background: rgba(168, 85, 247, 0.18); color: #d8b4fe; padding: 6px 14px; border-radius: 10px; font-size: 0.88rem; font-weight: 800; border: 1px solid rgba(168, 85, 247, 0.35); box-shadow: 0 4px 12px rgba(168, 85, 247, 0.2);">
            📅 <%= bookingDraft.preferredDate %> @ <%= bookingDraft.preferredTimeSlot %>
          </span>
          <div style="font-size: 0.85rem; color: #a78bfa; margin-top: 0.5rem; font-weight: 700;">
            📍 Service Location Settle Directly
          </div>
        </div>
      </div>
    </div>

    <!-- Doorstep Address Card -->
    <div style="margin-bottom: 2.25rem; padding: 1.25rem 1.5rem; background: rgba(59, 130, 246, 0.1); border-left: 5px solid #3b82f6; border-radius: 12px; display: flex; align-items: flex-start; gap: 1rem;">
      <span style="font-size: 1.5rem;">📍</span>
      <div>
        <strong style="color: #60a5fa; font-size: 0.92rem; display: block; margin-bottom: 0.3rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em;">Selected Doorstep Service Address:</strong>
        <p style="margin: 0; color: #f1f5f9; font-size: 1rem; line-height: 1.5; font-weight: 600;">
          <%= bookingDraft.serviceAddress || bookingDraft.addressArea %>
        </p>
      </div>
    </div>

    <% const isFullTime = (bookingDraft && bookingDraft.jobType === 'Full Time'); %>
    
    <% if (isFullTime) { %>
      <div style="margin-bottom: 2.25rem; padding: 1.5rem; background: rgba(245, 158, 11, 0.15); border: 2px solid #f59e0b; border-radius: 16px; color: #fff; box-shadow: 0 6px 24px rgba(245, 158, 11, 0.2);">
        <strong style="color: #fbbf24; font-size: 1.15rem; display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; font-weight: 800;">
          <span>⏳</span> Full Time Hiring Selected (Salary Negotiable On Site)
        </strong>
        <p style="margin: 0; font-size: 0.95rem; color: #fde68a; line-height: 1.6;">
          You are hiring <strong><%= professional.name %></strong> for full-time work. The monthly salary/charges will be negotiated and decided directly between you on site. To confirm this full-time booking right now, a mandatory one-time <strong>Platform Booking Fee of ₹250</strong> must be paid online via PayU.
        </p>
      </div>
    <% } %>

    <h3 style="color: #fff; font-size: 1.45rem; font-weight: 800; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.6rem;">
      <span>💳</span> <%= isFullTime ? 'Pay Platform Booking Fee (₹250)' : 'Choose Preferred Payment Method' %>
    </h3>

    <form method="POST" action="/book-service/<%= professional.id %>/confirm" style="width: 100%; box-sizing: border-box;">
      <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
        
        <% if (!isFullTime) { %>
          <!-- Option 1: Cash/UPI on completion (Part Time / Fixed) -->
          <label style="display: flex; align-items: flex-start; gap: 1.25rem; padding: 1.75rem; border-radius: 20px; border: 2px solid #38bdf8; background: rgba(56, 189, 248, 0.14); cursor: pointer; transition: all 0.2s; box-shadow: 0 6px 28px rgba(56, 189, 248, 0.18);" id="card-cod" onclick="selectPayment('cod')">
            <input type="radio" name="paymentMethod" id="radio-cod" value="cod" checked style="margin-top: 0.35rem; accent-color: #38bdf8; transform: scale(1.4); cursor: pointer;">
            <div style="flex: 1;">
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem; flex-wrap: wrap; gap: 0.5rem;">
                <strong style="color: #fff; font-size: 1.15rem; font-weight: 800; display: flex; align-items: center; gap: 0.5rem;">
                  🤝 Direct Post-Service Payment (Cash / UPI on Completion)
                </strong>
                <span style="background: #22c55e; color: #000; font-size: 0.75rem; font-weight: 800; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; letter-spacing: 0.04em;">Recommended</span>
              </div>
              <p style="margin: 0; font-size: 0.94rem; color: #cbd5e1; line-height: 1.6;">
                Part-time payment is fixed based on selected service rate. Settle payment directly with your professional after the work is completed without any upfront platform fee.
              </p>
            </div>
          </label>
        <% } %>

        <!-- Option 2: PayU Online Payment Gateway / Platform Fee -->
        <label style="display: flex; align-items: flex-start; gap: 1.25rem; padding: 1.75rem; border-radius: 20px; border: <%= isFullTime ? '2px solid #f59e0b' : '1px solid rgba(255,255,255,0.18)' %>; background: <%= isFullTime ? 'rgba(245, 158, 11, 0.15)' : 'rgba(15, 23, 42, 0.75)' %>; cursor: pointer; transition: all 0.2s; box-shadow: <%= isFullTime ? '0 6px 28px rgba(245, 158, 11, 0.22)' : 'none' %>;" id="card-payu" onclick="selectPayment('payu')">
          <input type="radio" name="paymentMethod" id="radio-payu" value="payu" <%= isFullTime ? 'checked' : '' %> style="margin-top: 0.35rem; accent-color: #f59e0b; transform: scale(1.4); cursor: pointer;">
          <div style="flex: 1;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem; flex-wrap: wrap; gap: 0.5rem;">
              <strong style="color: #fff; font-size: 1.15rem; font-weight: 800; display: flex; align-items: center; gap: 0.5rem;">
                🔒 <%= isFullTime ? 'Online PayU Payment — ₹250 Platform Booking Fee' : 'Online Payment via PayU Payment Gateway' %>
              </strong>
              <span style="background: #f59e0b; color: #000; font-size: 0.75rem; font-weight: 800; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; letter-spacing: 0.04em;"><%= isFullTime ? 'Mandatory Fee' : 'Instant & Secure' %></span>
            </div>
            <p style="margin: 0; font-size: 0.94rem; color: <%= isFullTime ? '#fde68a' : '#94a3b8' %>; line-height: 1.6;">
              <%= isFullTime
                ? 'Pay the ₹250 one-time platform booking fee online right now via PayU (UPI, Cards, NetBanking) to confirm your full-time professional booking.'
                : 'Pay online instantly and securely using Credit Card, Debit Card, UPI (Google Pay, PhonePe, Paytm), NetBanking, or Digital Wallets powered by PayU India.'
              %>
            </p>
            <div style="display: flex; gap: 0.6rem; align-items: center; margin-top: 1rem; flex-wrap: wrap;">
              <span style="font-size: 0.78rem; font-weight: 700; background: rgba(255,255,255,0.08); padding: 4px 10px; border-radius: 6px; color: #e2e8f0; border: 1px solid rgba(255,255,255,0.15);">⚡ UPI (GPay / PhonePe)</span>
              <span style="font-size: 0.78rem; font-weight: 700; background: rgba(255,255,255,0.08); padding: 4px 10px; border-radius: 6px; color: #e2e8f0; border: 1px solid rgba(255,255,255,0.15);">💳 Credit/Debit Cards</span>
              <span style="font-size: 0.78rem; font-weight: 700; background: rgba(255,255,255,0.08); padding: 4px 10px; border-radius: 6px; color: #e2e8f0; border: 1px solid rgba(255,255,255,0.15);">🏦 NetBanking</span>
              <span style="font-size: 0.78rem; font-weight: 700; background: rgba(34, 197, 94, 0.15); padding: 4px 10px; border-radius: 6px; color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3);">🛡️ 100% PayU Protected</span>
            </div>
          </div>
        </label>

      </div>

      <div style="display: flex; gap: 1.5rem; align-items: center; justify-content: space-between; border-top: 1px solid rgba(255,255,255,0.12); padding-top: 1.75rem; flex-wrap: wrap;">
        <a href="/book-service/<%= professional.id %>" style="color: #94a3b8; text-decoration: none; font-size: 1rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem; border-radius: 10px; transition: all 0.2s;">
          ‹ Back to Address Selection
        </a>
        <button type="submit" id="confirmSubmitBtn" class="button button-primary" style="padding: 1.2rem 2.8rem; font-size: 1.1rem; font-weight: 800; border-radius: 14px; background: linear-gradient(135deg, #38bdf8, #2563eb); box-shadow: 0 6px 28px rgba(37, 99, 235, 0.45); border: none; cursor: pointer; transition: all 0.2s;">
          <%= isFullTime ? 'Proceed to PayU Secure Payment (₹250) ›' : 'Confirm Booking & Settle Later ›' %>
        </button>
      </div>
    </form>
  </div>
</section>

<script>
  function selectPayment(type) {
    const cardCod = document.getElementById("card-cod");
    const cardPayu = document.getElementById("card-payu");
    const radioCod = document.getElementById("radio-cod");
    const radioPayu = document.getElementById("radio-payu");
    const submitBtn = document.getElementById("confirmSubmitBtn");

    if (type === 'cod') {
      if (radioCod) radioCod.checked = true;
      if (cardCod) {
        cardCod.style.border = "2px solid #38bdf8";
        cardCod.style.background = "rgba(56, 189, 248, 0.14)";
        cardCod.style.boxShadow = "0 6px 28px rgba(56, 189, 248, 0.18)";
      }
      if (cardPayu) {
        cardPayu.style.border = "1px solid rgba(255,255,255,0.18)";
        cardPayu.style.background = "rgba(15, 23, 42, 0.75)";
        cardPayu.style.boxShadow = "none";
      }
      if (submitBtn) submitBtn.innerHTML = "Confirm Booking & Settle Later ›";
    } else {
      if (radioPayu) radioPayu.checked = true;
      if (cardPayu) {
        cardPayu.style.border = "2px solid #f59e0b";
        cardPayu.style.background = "rgba(245, 158, 11, 0.15)";
        cardPayu.style.boxShadow = "0 6px 28px rgba(245, 158, 11, 0.22)";
      }
      if (cardCod) {
        cardCod.style.border = "1px solid rgba(255,255,255,0.18)";
        cardCod.style.background = "rgba(15, 23, 42, 0.75)";
        cardCod.style.boxShadow = "none";
      }
      if (submitBtn) submitBtn.innerHTML = "Proceed to PayU Secure Payment ›";
    }
  }
</script>
