<%- include("partials/header") %>

<section class="section shell" style="padding-top: 2rem; padding-bottom: 4rem; max-width: 800px; margin: 0 auto;">
  <div style="margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <div>
      <a href="/work" style="color: var(--color-brand); text-decoration: none; font-weight: 600; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 0.3rem;">
        ‹ Back to Work & Gigs
      </a>
      <h1 style="color: #fff; font-size: 1.8rem; margin: 0.4rem 0 0;">Work Discussion & Chat</h1>
      <p style="color: var(--color-ink-light); margin: 0.2rem 0 0; font-size: 0.95rem;">
        Job: <strong style="color: #fff;"><%= work ? work.category : 'General Requirement' %></strong> (<%= work ? work.location : 'Online' %>)
      </p>
    </div>
    <div style="background: rgba(255,255,255,0.05); padding: 0.6rem 1rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
      <span style="font-size: 0.82rem; color: var(--color-ink-light);">Chatting with:</span><br>
      <strong style="color: #a78bfa; font-size: 1rem;"><%= peerName || 'Peer' %></strong>
    </div>
  </div>

  <div class="glass-panel" style="display: flex; flex-direction: column; height: 500px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.15); background: rgba(15, 23, 42, 0.85); overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
    
    <!-- Chat Messages Window -->
    <div id="chat-messages-container" style="flex: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; scroll-behavior: smooth;">
      <% if (!messages || messages.length === 0) { %>
        <div style="text-align: center; margin: auto; color: var(--color-ink-light);">
          <span style="font-size: 2.5rem; display: block; margin-bottom: 0.5rem;">💬</span>
          <p style="font-size: 0.95rem; margin: 0;">No messages yet. Start the conversation to finalize job terms, timing, or address details!</p>
        </div>
      <% } else { %>
        <% messages.forEach(function(msg) { %>
          <% const isMe = (String(msg.senderId) === String(user.id) || String(msg.senderId) === String(user.email)); %>
          <div style="display: flex; flex-direction: column; max-width: 75%; align-self: <%= isMe ? 'flex-end' : 'flex-start' %>;">
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.2rem; padding: 0 0.3rem;">
              <span style="font-size: 0.75rem; font-weight: 700; color: <%= isMe ? '#a78bfa' : '#38bdf8' %>;"><%= isMe ? 'You' : msg.senderName %></span>
              <span style="font-size: 0.7rem; color: rgba(255,255,255,0.4);"><%= new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
            </div>
            <div style="padding: 0.85rem 1.1rem; border-radius: 14px; background: <%= isMe ? 'linear-gradient(135deg, #7c3aed, #6d28d9)' : 'rgba(255, 255, 255, 0.08)' %>; color: #fff; font-size: 0.95rem; line-height: 1.45; word-break: break-word; border: 1px solid <%= isMe ? 'rgba(167, 139, 250, 0.3)' : 'rgba(255,255,255,0.1)' %>; border-bottom-<%= isMe ? 'right' : 'left' %>-radius: 3px;">
              <%= msg.text %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- Message Input Bar -->
    <form action="/work/<%= work ? work.id : '' %>/chat/<%= peerId %>/send" method="POST" style="display: flex; gap: 0.75rem; padding: 1rem 1.25rem; background: rgba(0,0,0,0.4); border-top: 1px solid rgba(255,255,255,0.1);">
      <input type="text" name="text" required placeholder="Type your message here..." autocomplete="off" class="form-input" style="flex: 1; padding: 0.8rem 1.25rem; border-radius: 12px; background: rgba(255,255,255,0.06); color: #fff; border: 1px solid rgba(255,255,255,0.18); font-size: 0.95rem;">
      <button type="submit" class="button button-primary" style="padding: 0 1.5rem; border-radius: 12px; font-weight: 700; font-size: 0.95rem; background: linear-gradient(135deg, #a78bfa, #7c3aed); color: #fff; border: none; cursor: pointer;">
        Send 💬
      </button>
    </form>

  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const container = document.getElementById("chat-messages-container");
    if (container) {
      container.scrollTop = container.scrollHeight;
    }
  });
</script>

<%- include("partials/footer") %>
