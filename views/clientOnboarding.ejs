<section class="section shell animate-fade-in" style="max-width: 760px; margin: 0 auto; padding: 3rem 1.5rem;">
  
  <div class="glass-panel" style="padding: 2.5rem; border-radius: var(--radius-lg); background: rgba(15, 23, 42, 0.45); border: 1px solid var(--line-strong); text-align: center; margin-bottom: 2rem;">
    <span class="eyebrow" style="background: rgba(0, 242, 254, 0.15); color: #00f2fe; border: 1px solid rgba(0, 242, 254, 0.3); padding: 4px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">One-Time Profile Setup</span>
    <h1 style="font-family: 'Outfit', sans-serif; font-size: 2.2rem; color: #fff; margin-top: 1rem;">Complete Your Client Profile</h1>
    <p style="color: var(--text-soft); font-size: 0.95rem; max-width: 580px; margin: 0.5rem auto 0;">
      Please confirm your contact details and default location. We save this once so you never have to enter your address or pincode repeatedly when searching for professionals.
    </p>
  </div>

  <div class="glass-panel" style="padding: 3rem; border-radius: var(--radius-lg); border: 1px solid var(--line-strong); background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(20px);">
    <%- include("partials/notice") %>

    <form action="/client/onboarding" method="POST" style="display: flex; flex-direction: column; gap: 2rem;">
      
      <!-- Section 1: Contact Information -->
      <div style="border-bottom: 1px solid var(--line-strong); padding-bottom: 1.5rem;">
        <h3 style="font-family: 'Outfit', sans-serif; font-size: 1.2rem; color: #fff; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
          <span>👤</span> Personal Contact Details
        </h3>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
          <label class="field-group" style="display: flex; flex-direction: column; gap: 0.4rem;">
            <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-soft);">Full Name *</span>
            <input type="text" name="fullName" required value="<%= user && user.name ? user.name : '' %>" placeholder="Enter your full name" style="background: rgba(255,255,255,0.03); border: 1px solid var(--line); border-radius: 8px; padding: 12px 16px; color: #fff;">
          </label>
          
          <label class="field-group" style="display: flex; flex-direction: column; gap: 0.4rem;">
            <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-soft);">Phone Number *</span>
            <input type="tel" name="phone" required value="<%= user && user.phone ? user.phone : '' %>" placeholder="e.g. 9876543210" style="background: rgba(255,255,255,0.03); border: 1px solid var(--line); border-radius: 8px; padding: 12px 16px; color: #fff;">
          </label>
        </div>
      </div>

      <!-- Section 2: Address & Pincode -->
      <div style="border-bottom: 1px solid var(--line-strong); padding-bottom: 1.5rem;">
        <h3 style="font-family: 'Outfit', sans-serif; font-size: 1.2rem; color: #fff; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
          <span>📍</span> Default Service Location & Pincode
        </h3>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
          <label class="field-group" style="display: flex; flex-direction: column; gap: 0.4rem;">
            <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-soft);">City / Town *</span>
            <input type="text" name="city" id="clientCity" required value="<%= user && user.city ? user.city : '' %>" placeholder="e.g. Jaipur, Delhi, Mumbai" style="background: rgba(255,255,255,0.03); border: 1px solid var(--line); border-radius: 8px; padding: 12px 16px; color: #fff;">
          </label>

          <label class="field-group" style="display: flex; flex-direction: column; gap: 0.4rem;">
            <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-soft);">6-Digit Pincode *</span>
            <input type="text" name="pincode" id="clientPincode" required pattern="[0-9]{6}" maxlength="6" value="<%= user && user.pincode ? user.pincode : '' %>" placeholder="e.g. 302001" style="background: rgba(255,255,255,0.03); border: 1px solid var(--line); border-radius: 8px; padding: 12px 16px; color: #fff; font-weight: bold;">
          </label>
        </div>

        <label class="field-group" style="display: flex; flex-direction: column; gap: 0.4rem;">
          <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-soft);">Full House/Office Address *</span>
          <textarea name="address" required rows="2" placeholder="House/Flat No., Building Name, Street/Landmark" style="background: rgba(255,255,255,0.03); border: 1px solid var(--line); border-radius: 8px; padding: 12px 16px; color: #fff; resize: vertical;"><%= user && user.address ? user.address : '' %></textarea>
        </label>
      </div>

      <!-- Section 3: Password (Optional if via Google OAuth) -->
      <div>
        <h3 style="font-family: 'Outfit', sans-serif; font-size: 1.2rem; color: #fff; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
          <span>🔐</span> Set Account Password (Optional)
        </h3>
        <p style="font-size: 0.82rem; color: var(--text-soft); margin-bottom: 1.25rem;">
          If you signed in using Google or OTP, set a password below to allow standard email & password login.
        </p>
        
        <label class="field-group" style="display: flex; flex-direction: column; gap: 0.4rem;">
          <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-soft);">New Password (min 6 chars)</span>
          <input type="password" name="password" minlength="6" placeholder="Leave blank to keep existing / Google login" style="background: rgba(255,255,255,0.03); border: 1px solid var(--line); border-radius: 8px; padding: 12px 16px; color: #fff;">
        </label>
      </div>

      <!-- Submit Action -->
      <div style="margin-top: 1rem; display: flex; justify-content: flex-end;">
        <button type="submit" class="button button-primary" style="padding: 14px 32px; font-weight: 700; font-size: 1.05rem; border-radius: 50px; background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%); color: #0f172a; box-shadow: 0 8px 24px rgba(0, 242, 254, 0.3); border: none; cursor: pointer; transition: transform 0.2s ease;">
          Save & Proceed to Dashboard →
        </button>
      </div>

    </form>
  </div>

</section>
