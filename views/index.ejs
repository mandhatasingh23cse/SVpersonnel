<section class="hero-section">
  <div class="shell hero-grid">
    <div class="hero-copy" data-reveal>
      <p class="eyebrow"><%= homeContent.hero.eyebrow %></p>
      <h1><%= homeContent.hero.title %></h1>
      <p class="hero-description"><%= homeContent.hero.description %></p>

      <div class="hero-actions">
        <a href="/findHelpNow" class="button button-primary">Find professionals</a>
        <a href="/register" class="button button-secondary">Register as a professional</a>
      </div>

      <div class="pill-row">
        <% homeContent.hero.trustPills.forEach(function (pill) { %>
          <span class="info-pill"><%= pill %></span>
        <% }) %>
      </div>
    </div>

    <form class="hero-search-card glass-panel tilt-3d" action="/findHelpNow" method="GET" data-reveal>
      <p class="card-kicker">Quick search</p>
      <h2>Start with what you need.</h2>

      <label class="field-group">
        <span>Service or professional</span>
        <input
          type="text"
          name="skill"
          placeholder="<%= homeContent.hero.searchPlaceholder %>"
          autocomplete="off"
        >
      </label>

      <label class="field-group">
        <span>Location</span>
        <input
          type="text"
          name="city"
          value="<%= brand.city %>"
          placeholder="<%= homeContent.hero.locationPlaceholder %>"
          autocomplete="off"
        >
      </label>

      <div class="chip-picker">
        <% homeContent.hero.quickSearches.forEach(function (item) { %>
          <button type="button" class="chip-button" data-fill-target="skill" data-fill-value="<%= item %>">
            <%= item %>
          </button>
        <% }) %>
      </div>

      <button type="submit" class="button button-primary button-block">Search now</button>

      <div class="hero-stats">
        <% homeContent.hero.stats.forEach(function (stat) { %>
          <div class="stat-card">
            <strong><%= stat.value %></strong>
            <span><%= stat.label %></span>
          </div>
        <% }) %>
      </div>
    </form>
  </div>
</section>

<section class="section shell">
  <div class="section-heading" data-reveal>
    <p class="eyebrow">Popular services</p>
    <h2>Browse the categories people search most.</h2>
  </div>

  <div class="service-grid">
    <% homeContent.services.forEach(function (service) { %>
      <a class="service-card glass-panel tilt-3d" data-reveal href="/findHelpNow?skill=<%= encodeURIComponent(service.name) %>&city=<%= encodeURIComponent(brand.city) %>">
        <div class="service-icon-wrap">
          <img src="<%= service.icon %>" alt="<%= service.name %>">
        </div>
        <h3><%= service.name %></h3>
        <p><%= service.description %></p>
        <% if (service.priceLabel || service.meta) { %>
          <div class="service-meta">
            <% if (service.priceLabel) { %>
              <span><%= service.priceLabel %></span>
            <% } %>
            <% if (service.meta) { %>
              <span><%= service.meta %></span>
            <% } %>
          </div>
        <% } %>
      </a>
    <% }) %>
  </div>
</section>

<section class="section shell">
  <div class="section-heading" data-reveal>
    <p class="eyebrow">Why GigConnect</p>
    <h2>Everything you need to choose with confidence.</h2>
  </div>

  <div class="feature-grid">
    <% homeContent.capabilities.forEach(function (item) { %>
      <article class="feature-card glass-panel tilt-3d" data-reveal>
        <h3><%= item.title %></h3>
        <p><%= item.description %></p>
      </article>
    <% }) %>
  </div>
</section>

<section class="section shell">
  <div class="section-heading" data-reveal>
    <p class="eyebrow">How it works</p>
    <h2>Three clear steps from search to contact.</h2>
  </div>

  <div class="step-grid">
    <% homeContent.steps.forEach(function (step) { %>
      <article class="step-card glass-panel tilt-3d" data-reveal>
        <span class="step-number"><%= step.step %></span>
        <h3><%= step.title %></h3>
        <p><%= step.description %></p>
      </article>
    <% }) %>
  </div>
</section>

<section class="section shell">
  <div class="split-panel">
    <% homeContent.personas.forEach(function (persona, index) { %>
      <article class="persona-card glass-panel tilt-3d" data-reveal>
        <span class="mini-badge"><%= persona.badge %></span>
        <h3><%= persona.title %></h3>
        <p><%= persona.description %></p>
        <ul class="check-list">
          <% persona.bullets.forEach(function (bullet) { %>
            <li><%= bullet %></li>
          <% }) %>
        </ul>

        <div class="persona-actions">
          <% if (index === 0) { %>
            <a href="/findHelpNow" class="button button-primary">Find professionals</a>
          <% } else { %>
            <a href="/register" class="button button-primary">Join GigConnect</a>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="section shell">
  <div class="section-heading" data-reveal>
    <p class="eyebrow">Featured professionals</p>
    <h2>Professionals you can review quickly and trust faster.</h2>
  </div>

  <div class="featured-worker-grid">
    <% featuredWorkers.forEach(function (worker) { const skills = Array.isArray(worker.skills) ? worker.skills : []; const rawPhone = String(worker.phone || worker.contact || ""); const phoneDigits = rawPhone.replace(/[^\d]/g, ""); const phoneDisplay = phoneDigits.length === 10 ? `+91 ${phoneDigits.slice(0, 5)} ${phoneDigits.slice(5)}` : rawPhone; const emailDisplay = String(worker.email || ""); const hasDirectContact = Boolean(phoneDisplay || emailDisplay); const contactPanelId = `featured-contact-${worker.id || worker._id}`; %>
      <article class="worker-preview glass-panel" data-reveal>
        <div class="worker-preview-head">
          <img src="<%= encodeURI(worker.photo) %>" alt="<%= worker.name %>" class="worker-preview-avatar">
          <div>
            <h3><%= worker.name %></h3>
            <p><%= worker.city %></p>
          </div>
        </div>

        <div class="worker-preview-badges">
          <span class="result-badge is-rating"><%= Number(worker.ratings || 0).toFixed(1) %> / 5</span>
          <% if (worker.isVerified) { %>
            <span class="result-badge is-verified">Verified</span>
          <% } else { %>
            <span class="result-badge">New profile</span>
          <% } %>
        </div>

        <p class="worker-preview-meta"><%= worker.experience %> years experience | <%= worker.distance %> km away</p>
        <% if (worker.startingPrice) { %>
          <p class="worker-preview-rate">Starts at <%= formatCurrency(worker.startingPrice) %></p>
        <% } %>

        <div class="worker-preview-skills">
          <% skills.slice(0, 3).forEach(function (skill) { %>
            <span class="skill-tag"><%= skill %></span>
          <% }) %>
        </div>

        <div class="worker-preview-actions">
          <a href="/book-service/<%= worker.id || worker._id %>" class="button button-primary">Book now</a>
          <a href="/findHelpNow?skill=<%= encodeURIComponent(skills[0] || worker.name) %>&city=<%= encodeURIComponent(worker.city) %>" class="button button-secondary">View similar</a>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="section shell">
  <div class="section-heading" data-reveal>
    <p class="eyebrow">Reviews</p>
    <h2>What people say after using GigConnect.</h2>
  </div>

  <div class="testimonial-grid">
    <% homeContent.testimonials.forEach(function (item) { %>
      <article class="testimonial-card glass-panel" data-reveal>
        <div class="testimonial-stars">
          <%= "★".repeat(item.rating || 5) %><%= "☆".repeat(5 - (item.rating || 5)) %>
        </div>
        <blockquote style="font-size: 1.05rem; line-height: 1.7; font-style: italic; margin: 0 0 1.5rem 0; position: relative; z-index: 1;">
          "<%= item.quote %>"
        </blockquote>
        <div class="testimonial-person" style="border-top: 1px solid var(--line); padding-top: 1rem;">
          <img src="<%= item.image %>" alt="<%= item.name %>" style="border: 2px solid var(--line-strong);">
          <div>
            <h3 style="font-size: 1.05rem; font-weight: 700; margin: 0;"><%= item.name %></h3>
            <p style="font-size: 0.85rem; margin: 2px 0 0 0; color: var(--text-soft); font-weight: 600;"><%= item.role %></p>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>
