<section class="page-hero">
  <div class="shell page-hero-content">
    <p class="eyebrow">Client dashboard</p>
    <h1>Track your live booking requests.</h1>
    <p>Every request you create is stored in Supabase and appears here with status, budget, and schedule details.</p>
  </div>
</section>

<section class="section shell dashboard-shell">
  <%- include("partials/notice") %>

  <%
    const liveBookings = dashboardData.bookings.filter(b => b.status !== 'completed' && b.status !== 'cancelled');
    const historyBookings = dashboardData.bookings.filter(b => b.status === 'completed' || b.status === 'cancelled');
  %>

  <div class="dashboard-metrics">
    <article class="metric-card glass-panel" data-reveal style="cursor: pointer;" onclick="toggleHistorySection(true)">
      <strong><%= dashboardData.summary.totalBookings %></strong>
      <h3 style="color: #38bdf8;">Total Requests & History</h3>
      <p>Click to view all archived, completed & past requests.</p>
    </article>
    <article class="metric-card glass-panel" data-reveal>
      <strong><%= dashboardData.summary.confirmedBookings %></strong>
      <h3>Confirmed</h3>
      <p>Requests that a professional has accepted for service.</p>
    </article>
    <article class="metric-card glass-panel" data-reveal>
      <strong><%= dashboardData.summary.pendingBookings %></strong>
      <h3>Pending</h3>
      <p>Requests waiting for confirmation or scheduling.</p>
    </article>
  </div>

  <div style="margin: 2.5rem 0 1.25rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 1rem;">
    <div>
      <span style="background: rgba(56, 189, 248, 0.15); color: #38bdf8; font-size: 0.75rem; font-weight: 800; padding: 3px 10px; border-radius: 6px; text-transform: uppercase;">Active Flow</span>
      <h2 style="font-size: 1.6rem; margin: 0.35rem 0 0; color: #fff;">🔥 Live & Uncompleted Bookings (<%= liveBookings.length %>)</h2>
    </div>
    <button type="button" id="history-toggle-btn" onclick="toggleHistorySection()" style="color: #38bdf8; font-weight: 700; cursor: pointer; font-size: 0.92rem; background: rgba(56, 189, 248, 0.12); padding: 0.6rem 1.2rem; border-radius: 12px; border: 1px solid rgba(56, 189, 248, 0.35); display: inline-flex; align-items: center; gap: 0.4rem;">
      📜 View Total Requests & History (<%= historyBookings.length %>) ›
    </button>
  </div>

  <div class="dashboard-list">
    <% if (!liveBookings.length) { %>
      <div class="empty-state" style="padding: 3rem 2rem; border: 1px dashed rgba(255,255,255,0.2); border-radius: 20px;">
        <h3>No live uncompleted bookings right now.</h3>
        <p>Your completed or cancelled bookings are saved below in the <strong>Total Requests & History</strong> box.</p>
        <div class="empty-actions" style="margin-top: 1.25rem;">
          <a href="/findHelpNow" class="button button-primary">Find professionals to Book ›</a>
        </div>
      </div>
    <% } %>

    <% liveBookings.forEach(function (booking) { %>
      <article class="dashboard-card glass-panel" data-reveal style="width: 100%; box-sizing: border-box;">
        <div class="dashboard-card-top">
          <div class="dashboard-header-copy">
            <p class="card-kicker">Booking <%= booking.bookingCode %></p>
            <h2><%= booking.professionalName %></h2>
          </div>
          <span class="result-badge status-badge-<%= booking.status %>"><%= formatStatusLabel(booking.status) %></span>
        </div>

        <div class="dashboard-grid">
          <div class="dashboard-detail">
            <span class="dashboard-label">Service</span>
            <strong><%= booking.serviceName %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Date</span>
            <strong><%= formatShortDate(booking.preferredDate) %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Time</span>
            <strong><%= formatTimeSlot(booking.preferredTimeSlot) %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Fixed Day Price</span>
            <strong><%= formatCurrency(booking.budgetInr) %></strong>
          </div>
          <div class="dashboard-detail dashboard-detail-wide">
            <span class="dashboard-label">Complete Doorstep Address</span>
            <% 
              let dirUrlClient = null;
              if (booking.details && booking.details.includes("[Coordinates:")) {
                const matchC = booking.details.match(/\[Coordinates:\s*([^,]+),\s*([^\]]+)\]/);
                if (matchC) {
                  dirUrlClient = `https://www.google.com/maps/dir/?api=1&destination=${matchC[1]},${matchC[2]}`;
                }
              }
              if (!dirUrlClient) {
                dirUrlClient = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(booking.addressArea)}`;
              }
            %>
            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; gap: 1rem; flex-wrap: wrap;">
              <strong><%= booking.addressArea %></strong>
              <a href="<%= dirUrlClient %>" target="_blank" rel="noopener noreferrer" style="font-size: 0.85rem; font-weight: 700; color: #38bdf8; text-decoration: none; display: flex; align-items: center; gap: 0.25rem; background: rgba(56, 189, 248, 0.15); padding: 0.5rem 0.85rem; border-radius: var(--radius-sm); border: 1px solid #38bdf8;">
                📍 View on Google Maps Navigation
              </a>
            </div>
          </div>
          <div class="dashboard-detail dashboard-detail-wide">
            <span class="dashboard-label">Professional area</span>
            <strong><%= booking.professionalArea %>, <%= booking.professionalCity %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Professional Phone</span>
            <strong><%= booking.professionalPhone || "Not shared" %></strong>
          </div>
          <div class="dashboard-detail">
            <span class="dashboard-label">Professional Email</span>
            <strong><%= booking.professionalEmail || "Not shared" %></strong>
          </div>
        </div>

        <%
          let otp = null;
          let workStartedAt = null;
          let workCompletedAt = null;
          let totalPayment = null;
          if (booking.details) {
            const otpMatch = booking.details.match(/\[Start OTP:\s*(\d+)\]/);
            const startedMatch = booking.details.match(/\[Work Started At:\s*([^\]]+)\]/);
            const completedMatch = booking.details.match(/\[Work Completed At:\s*([^\]]+)\]/);
            const paymentMatch = booking.details.match(/\[Total Payment:\s*(\d+)\]/);
            if (otpMatch) otp = otpMatch[1];
            if (startedMatch) workStartedAt = startedMatch[1];
            if (completedMatch) workCompletedAt = completedMatch[1];
            if (paymentMatch) totalPayment = paymentMatch[1];
          }
        %>

        <% if (booking.details) { %>
          <p class="result-description"><%=- booking.details.replace(/\n/g, '<br>') %></p>
        <% } %>

        <% if (booking.status === 'confirmed' && otp && !workStartedAt) { %>
          <div style="margin: 1.25rem 0; padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--accent-soft); background: rgba(124, 58, 237, 0.04); text-align: center;">
            <span style="font-size: 0.85rem; color: var(--text-soft); display: block; margin-bottom: 0.25rem;">🔑 OTP to Start Work</span>
            <strong style="font-size: 1.75rem; letter-spacing: 4px; color: var(--accent);"><%= otp %></strong>
            <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0.5rem 0 0 0; line-height: 1.4;">Share this OTP with the professional when they arrive to start the service timer.</p>
          </div>
        <% } %>

        <% if (booking.status === 'confirmed' && workStartedAt && !workCompletedAt) { %>
          <div style="margin: 1.25rem 0; padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--accent-soft); background: rgba(124, 58, 237, 0.04); text-align: center;">
            <span style="font-weight: 700; color: var(--accent); display: block; margin-bottom: 0.25rem;">⚡ Service In Progress (Day Rate Fixed)</span>
            <span id="timer-<%= booking.id %>" data-start-time="<%= workStartedAt %>" data-fixed-rate="<%= booking.budgetInr || 500 %>" style="font-family: monospace; font-size: 1.1rem; font-weight: bold; color: var(--text);">00:00:00 (Fixed Charge: ₹<%= booking.budgetInr || 500 %>)</span>
          </div>
        <% } %>

        <% if (workCompletedAt) { %>
          <div style="margin: 1.25rem 0; padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--success); background: rgba(16, 185, 129, 0.04); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem;">
            <div style="text-align: left;">
              <span style="font-size: 0.85rem; color: var(--text-soft); display: block;">Final Service Charge</span>
              <strong style="font-size: 1.25rem; color: var(--success);">₹<%= totalPayment %></strong>
            </div>
            
            <span class="result-badge is-verified" style="padding: 8px 14px; font-size: 0.85rem; font-weight: 700; background: rgba(16, 185, 129, 0.15); border-color: var(--success); color: var(--success);">✅ Work Completed (Direct Settlement)</span>
          </div>
        <% } %>

        <% if ((booking.status === 'pending' || booking.status === 'confirmed') && !workStartedAt) { %>
          <div style="margin-top: 1.25rem; display: flex; justify-content: flex-end;">
            <button type="button" class="button button-danger" style="background: var(--error); border-color: var(--error);" data-cancel-booking-btn data-booking-id="<%= booking.id %>" data-booking-code="<%= booking.bookingCode %>" data-booking-status="<%= booking.status %>">Cancel booking</button>
          </div>
        <% } %>

        <% if (booking.review) { %>
          <section class="glass-inset dashboard-review-panel">
            <div class="dashboard-review-head">
              <div>
                <p class="card-kicker">Your review</p>
                <h3><%= booking.review.rating %> / 5 rating</h3>
              </div>
              <p class="dashboard-review-date">Submitted on <%= formatShortDate(booking.review.createdAt) %></p>
            </div>

            <% if (booking.review.reviewText) { %>
              <p class="dashboard-review-copy"><%= booking.review.reviewText %></p>
            <% } else { %>
              <p class="dashboard-review-copy is-muted">You submitted a rating without a written review.</p>
            <% } %>
          </section>
        <% } %>

        <% if (booking.canReview) { %>
          <form method="POST" action="/client/bookings/<%= booking.id %>/review" class="glass-inset dashboard-review-form">
            <div class="dashboard-review-head">
              <div class="dashboard-review-copy-block">
                <p class="card-kicker">Rate this professional</p>
                <h3>Share your completed-service feedback.</h3>
                <p class="dashboard-review-date">Your rating updates the live professional score.</p>
              </div>
            </div>

            <div class="dashboard-review-grid">
              <div class="dashboard-review-side">
                <label class="field-group">
                  <span>Rating</span>
                  <select name="rating" required>
                    <option value="">Select rating</option>
                    <option value="5">5 - Excellent</option>
                    <option value="4">4 - Good</option>
                    <option value="3">3 - Average</option>
                    <option value="2">2 - Needs improvement</option>
                    <option value="1">1 - Poor</option>
                  </select>
                </label>

                <div class="dashboard-actions dashboard-review-actions">
                  <button type="submit" class="button button-primary">Submit rating</button>
                </div>
              </div>

              <label class="field-group dashboard-review-field-wide">
                <span>Review message</span>
                <textarea name="reviewText" rows="3" placeholder="Tell others how the service went, what was good, and whether you would book again."></textarea>
              </label>
            </div>
          </form>
        <% } %>
      </article>
    <% }) %>
  </div>

  <!-- Total Requests & History Box (Hidden by default, shown on click) -->
  <script>
    function toggleHistorySection(show) {
      const sec = document.getElementById('history-section');
      const btn = document.getElementById('history-toggle-btn');
      if (!sec) return;
      const isHidden = sec.style.display === 'none' || sec.style.display === '';
      if (show !== undefined ? show : isHidden) {
        sec.style.display = 'block';
        sec.scrollIntoView({ behavior: 'smooth' });
        if (btn) btn.innerHTML = '🙈 Hide Total Requests & History (<%= historyBookings.length %>) ›';
      } else {
        sec.style.display = 'none';
        if (btn) btn.innerHTML = '📜 View Total Requests & History (<%= historyBookings.length %>) ›';
      }
    }
  </script>
  <div id="history-section" style="display: none; margin-top: 3rem; padding-top: 2.5rem; border-top: 2px solid rgba(255, 255, 255, 0.15);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
      <div>
        <span style="background: rgba(168, 85, 247, 0.18); color: #d8b4fe; border: 1px solid rgba(168, 85, 247, 0.3); padding: 3px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Archived Records</span>
        <h2 style="font-size: 1.8rem; margin: 0.35rem 0 0; color: #fff;">Total Requests & History (<%= historyBookings.length %>)</h2>
      </div>
      <p style="color: #94a3b8; font-size: 0.9rem; margin: 0;">Completed & Cancelled requests stored safely.</p>
    </div>

    <% if (!historyBookings.length) { %>
      <div class="glass-panel" style="padding: 2.5rem; text-align: center; border-radius: 18px; border: 1px dashed rgba(255,255,255,0.15);">
        <h3 style="color: #cbd5e1; margin: 0 0 0.5rem;">No past or completed requests yet.</h3>
        <p style="color: #64748b; font-size: 0.9rem; margin: 0;">When your active bookings finish or get completed, they automatically move into this History section.</p>
      </div>
    <% } else { %>
      <div class="dashboard-list">
        <% historyBookings.forEach(function (booking) { %>
          <article class="dashboard-card glass-panel" data-reveal style="width: 100%; box-sizing: border-box; opacity: 0.9;">
            <div class="dashboard-card-top">
              <div class="dashboard-header-copy">
                <p class="card-kicker">Booking <%= booking.bookingCode %></p>
                <h2><%= booking.professionalName %></h2>
              </div>
              <span class="result-badge status-badge-<%= booking.status %>"><%= formatStatusLabel(booking.status) %></span>
            </div>

            <div class="dashboard-grid">
              <div class="dashboard-detail">
                <span class="dashboard-label">Service</span>
                <strong><%= booking.serviceName %></strong>
              </div>
              <div class="dashboard-detail">
                <span class="dashboard-label">Date</span>
                <strong><%= formatShortDate(booking.preferredDate) %></strong>
              </div>
              <div class="dashboard-detail">
                <span class="dashboard-label">Time</span>
                <strong><%= formatTimeSlot(booking.preferredTimeSlot) %></strong>
              </div>
              <div class="dashboard-detail">
                <span class="dashboard-label">Day Price</span>
                <strong><%= formatCurrency(booking.budgetInr) %></strong>
              </div>
            </div>

            <% if (booking.status === 'completed') { %>
              <div style="margin-top: 1rem; padding: 1rem; border-radius: 12px; background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.25); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
                <span style="color: var(--success); font-weight: 700; font-size: 0.9rem;">✅ Service Completed Successfully</span>
                <% if (booking.review) { %>
                  <span style="color: #e2e8f0; font-size: 0.85rem; background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 8px;">Your Rating: ⭐ <%= booking.review.rating %> / 5</span>
                <% } %>
              </div>
            <% } else if (booking.status === 'cancelled') { %>
              <div style="margin-top: 1rem; padding: 1rem; border-radius: 12px; background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.25);">
                <span style="color: #f87171; font-weight: 700; font-size: 0.9rem;">🚫 Booking Cancelled</span>
              </div>
            <% } %>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Cancellation Modal -->
  <div id="cancel-modal-backdrop" class="reviews-modal-backdrop">
    <div class="reviews-modal" style="width: min(500px, 100%);">
      <div class="reviews-modal-header">
        <h2>Cancel Booking <span id="cancel-booking-code"></span></h2>
        <button class="reviews-modal-close" id="close-cancel-modal">&times;</button>
      </div>
      <div class="reviews-modal-body">
        <div id="cancel-warning-text"></div>

        <form id="cancel-booking-form" method="POST" action="" style="margin-top: 1.5rem; display: flex; justify-content: flex-end; gap: 1rem;">
          <button type="button" class="button button-secondary" id="cancel-modal-back-btn">Go back</button>
          <button type="submit" class="button button-danger" style="background: var(--error); border-color: var(--error);">Confirm Cancellation</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const cancelBtnList = document.querySelectorAll("[data-cancel-booking-btn]");
      const backdrop = document.getElementById("cancel-modal-backdrop");
      const closeBtn = document.getElementById("close-cancel-modal");
      const backBtn = document.getElementById("cancel-modal-back-btn");
      const form = document.getElementById("cancel-booking-form");
      const codeSpan = document.getElementById("cancel-booking-code");
      const warningText = document.getElementById("cancel-warning-text");

      cancelBtnList.forEach(btn => {
        btn.addEventListener("click", () => {
          const bookingId = btn.dataset.bookingId;
          const bookingCode = btn.dataset.bookingCode;
          const status = btn.dataset.bookingStatus;

          codeSpan.textContent = `(${bookingCode})`;
          form.action = `/client/bookings/${bookingId}/cancel`;

          if (status === "confirmed") {
            warningText.innerHTML = `
              <p style="color: var(--text); font-weight: 600; margin: 0;">Warning: This booking is already confirmed by the professional.</p>
              <p style="color: var(--text-muted); font-size: 0.95rem; margin-top: 0.5rem; line-height: 1.5;">Canceling a confirmed booking affects the professional's schedule. Repeated cancellations (more than 10) will result in your account being permanently blocked.</p>
            `;
          } else {
            warningText.innerHTML = `
              <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.5; margin: 0;">Are you sure you want to cancel this pending request? This action cannot be undone.</p>
            `;
          }

          backdrop.classList.add("is-open");
        });
      });

      const closeModal = () => backdrop.classList.remove("is-open");
      closeBtn.addEventListener("click", closeModal);
      backBtn.addEventListener("click", closeModal);
      backdrop.addEventListener("click", (e) => {
        if (e.target === backdrop) closeModal();
      });
    });
  </script>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Live timers
      const timerElements = document.querySelectorAll("[id^='timer-']");

      function updateTimers() {
        timerElements.forEach(el => {
          const startTimeStr = el.dataset.startTime;
          const fixedRate = Number(el.dataset.fixedRate || 500);
          if (!startTimeStr) return;

          const start = new Date(startTimeStr).getTime();
          const now = Date.now();
          const diffMs = now - start;

          const hours = Math.floor(diffMs / 3600000);
          const minutes = Math.floor((diffMs % 3600000) / 60000);
          const seconds = Math.floor((diffMs % 60000) / 1000);

          const timeStr = [
            String(hours).padStart(2, '0'),
            String(minutes).padStart(2, '0'),
            String(seconds).padStart(2, '0')
          ].join(':');

          el.textContent = `${timeStr} (Fixed Day Charge: ₹${fixedRate})`;
        });
      }

      setInterval(updateTimers, 1000);
      updateTimers();
    });
  </script>
</section>
