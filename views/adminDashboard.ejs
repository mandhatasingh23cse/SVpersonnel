<section class="page-hero">
  <div class="shell page-hero-content">
    <p class="eyebrow">Super Admin Dashboard</p>
    <h1>Welcome, Administrator</h1>
    <p>Manage support tickets, review partner registrations, and oversee site metrics.</p>
  </div>
</section>

<section class="section shell">
  <%- include("partials/notice") %>

  <!-- Overview Stats Grid -->
  <div class="stats-panel" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
    <div class="glass-panel" style="padding: 1.5rem; text-align: center; border-radius: var(--radius-large);">
      <h2 style="font-size: 2.5rem; font-family: var(--font-display); color: var(--color-ink); margin-bottom: 0.5rem;"><%= dashboardData.metrics.totalClients %></h2>
      <p style="text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.85rem; color: var(--color-ink-light);">Total Clients</p>
    </div>
    
    <div class="glass-panel" style="padding: 1.5rem; text-align: center; border-radius: var(--radius-large);">
      <h2 style="font-size: 2.5rem; font-family: var(--font-display); color: var(--color-ink); margin-bottom: 0.5rem;"><%= dashboardData.metrics.totalProfessionals %></h2>
      <p style="text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.85rem; color: var(--color-ink-light);">Active Partners</p>
    </div>

    <div class="glass-panel" style="padding: 1.5rem; text-align: center; border-radius: var(--radius-large);">
      <h2 style="font-size: 2.5rem; font-family: var(--font-display); color: var(--color-ink); margin-bottom: 0.5rem;"><%= dashboardData.metrics.totalBookings %></h2>
      <p style="text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.85rem; color: var(--color-ink-light);">Total Bookings</p>
    </div>

    <div class="glass-panel" style="padding: 1.5rem; text-align: center; border-radius: var(--radius-large); background: rgba(212, 163, 89, 0.1); border-color: rgba(212, 163, 89, 0.3);">
      <h2 style="font-size: 2.5rem; font-family: var(--font-display); color: var(--color-brand); margin-bottom: 0.5rem;"><%= dashboardData.metrics.pendingSupport %></h2>
      <p style="text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.85rem; color: var(--color-brand);">Pending Tickets</p>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr; gap: 3rem;">
    <!-- SECTION 1: Support Inbox -->
    <div class="glass-panel" style="padding: 2.5rem; border-radius: var(--radius-large);">
      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--color-border); padding-bottom: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <h2 style="font-family: var(--font-display); margin-bottom: 0.25rem;">Support &amp; Inquiry Inbox</h2>
          <p style="color: var(--color-ink-light); font-size: 0.95rem;">Answer queries and review platform support requests.</p>
        </div>
      </div>

      <% if (!dashboardData.supportMessages.length) { %>
        <p style="text-align: center; color: var(--color-ink-light); padding: 3rem 0;">No support inquiries found in the database.</p>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          <% dashboardData.supportMessages.forEach(function (msg) { %>
            <div style="padding: 2rem; border-radius: var(--radius-medium); background: rgba(255, 255, 255, 0.4); border: 1px solid var(--color-border); display: flex; flex-direction: column; gap: 1rem;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
                <div>
                  <span style="display: inline-block; padding: 0.25rem 0.75rem; font-size: 0.8rem; font-weight: 600; border-radius: 99px; text-transform: uppercase; margin-bottom: 0.5rem; 
                    <%= msg.status === 'resolved' ? 'background: rgba(46, 117, 89, 0.15); color: #2e7559;' : 'background: rgba(212, 163, 89, 0.15); color: var(--color-brand);' %>">
                    <%= msg.status === 'resolved' ? 'Resolved' : 'Pending Action' %>
                  </span>
                  <h3 style="font-family: var(--font-display); font-size: 1.2rem; margin-bottom: 0.25rem;"><%= msg.subject || "No Subject" %></h3>
                  <p style="font-size: 0.9rem; color: var(--color-ink-light);">
                    From: <strong><%= msg.full_name %></strong> (<%= msg.email %>) 
                    <% if (msg.phone) { %> | Phone: <%= msg.phone %><% } %>
                  </p>
                </div>
                <span style="font-size: 0.85rem; color: var(--color-ink-light);"><%= formatShortDate(msg.created_at) %></span>
              </div>

              <div style="padding: 1rem; border-radius: var(--radius-small); background: rgba(255,255,255,0.6); font-size: 0.95rem; border-left: 3px solid var(--color-brand);">
                <%= msg.message %>
              </div>

              <% if (msg.status === 'resolved') { %>
                <div style="margin-top: 0.5rem; padding: 1.25rem; border-radius: var(--radius-small); background: rgba(46, 117, 89, 0.05); border: 1px solid rgba(46, 117, 89, 0.15);">
                  <p style="font-size: 0.85rem; color: #2e7559; font-weight: 600; margin-bottom: 0.5rem;">Admin Response (replied on <%= formatShortDate(msg.replied_at) %>):</p>
                  <p style="font-size: 0.95rem; line-height: 1.6;"><%= msg.admin_reply %></p>
                </div>
              <% } else { %>
                <form action="/admin/support/<%= msg.id %>/reply" method="POST" style="margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.75rem;">
                  <label class="field-group" style="margin-bottom: 0;">
                    <span style="font-weight: 600; font-size: 0.85rem;">Write official reply:</span>
                    <textarea name="replyText" rows="3" placeholder="Write response to user... (this updates status to resolved)" required style="padding: 1rem; border-radius: var(--radius-small);"></textarea>
                  </label>
                  <button type="submit" class="button button-primary" style="align-self: flex-end;">Save &amp; Resolve Ticket</button>
                </form>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- SECTION 2: Professional Partner Registrations -->
    <div class="glass-panel" style="padding: 2.5rem; border-radius: var(--radius-large);">
      <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 1.5rem; margin-bottom: 2rem;">
        <h2 style="font-family: var(--font-display); margin-bottom: 0.25rem;">Partner Registrations</h2>
        <p style="color: var(--color-ink-light); font-size: 0.95rem;">Review, verify, or remove registered service professionals.</p>
      </div>

      <% if (!dashboardData.professionals.length) { %>
        <p style="text-align: center; color: var(--color-ink-light); padding: 3rem 0;">No professional applications or profiles registered yet.</p>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 2.5rem;">
          <% dashboardData.professionals.forEach(function (pro) { %>
            <div style="padding: 2rem; border-radius: var(--radius-medium); background: rgba(255,255,255,0.4); border: 1px solid var(--color-border); display: grid; grid-template-columns: auto 1fr; gap: 2rem; align-items: start; flex-wrap: wrap;">
              <img src="<%= encodeURI(pro.photo) %>" alt="<%= pro.name %>" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid var(--color-border);">
              
              <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
                  <div>
                    <h3 style="font-family: var(--font-display); font-size: 1.25rem; display: flex; align-items: center; gap: 0.75rem;">
                      <%= pro.name %>
                      <span style="font-size: 0.75rem; padding: 0.15rem 0.5rem; border-radius: 4px; font-weight: 600; text-transform: uppercase; 
                        <%= pro.isVerified ? 'background: rgba(46,117,89,0.15); color: #2e7559;' : 'background: rgba(212,163,89,0.15); color: var(--color-brand);' %>">
                        <%= pro.isVerified ? 'Verified Partner' : 'Pending Verification' %>
                      </span>
                    </h3>
                    <p style="font-size: 0.9rem; color: var(--color-ink-light); margin-top: 0.25rem;">
                      Email: <%= pro.email %> | Phone: <%= pro.phone %> | City: <%= pro.city %> (<%= pro.area %>)
                    </p>
                  </div>
                </div>

                <div style="display: flex; gap: 1.5rem; font-size: 0.85rem; color: var(--color-ink-light); border-top: 1px solid rgba(0,0,0,0.05); border-bottom: 1px solid rgba(0,0,0,0.05); padding: 0.75rem 0;">
                  <span><strong>Experience:</strong> <%= pro.experience %> Years</span>
                  <span><strong>Starting rate:</strong> <%= formatCurrency(pro.startingPrice) %></span>
                </div>

                <div>
                  <h4 style="font-size: 0.85rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--color-ink-light);">Skills / Categories:</h4>
                  <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                    <% pro.skills.forEach(function (skill) { %>
                      <span class="skill-tag" style="font-size: 0.8rem; padding: 0.15rem 0.5rem;"><%= skill %></span>
                    <% }) %>
                  </div>
                </div>

                <% if (pro.description) { %>
                  <div>
                    <h4 style="font-size: 0.85rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--color-ink-light);">Bio:</h4>
                    <p style="font-size: 0.9rem; line-height: 1.6; color: var(--color-ink);"><%= pro.description %></p>
                  </div>
                <% } %>

                <% if (pro.aadhaarPanUrl || pro.livePhotoUrl) { %>
                  <div style="margin-top: 1rem; border-top: 1px dashed var(--line); padding-top: 1rem;">
                    <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text);">Identity Verification Documents:</h4>
                    <div style="display: flex; gap: 2rem; align-items: flex-start; flex-wrap: wrap;">
                      <% if (pro.aadhaarPanUrl) { %>
                        <div style="display: grid; gap: 0.5rem;">
                          <span style="font-size: 0.8rem; font-weight: 700; color: var(--text-soft); text-transform: uppercase;">ID Document (Aadhaar/PAN)</span>
                          <% if (pro.aadhaarPanUrl.toLowerCase().endsWith('.pdf')) { %>
                            <a href="<%= pro.aadhaarPanUrl %>" target="_blank" class="button button-secondary" style="min-height: 40px; padding: 0 16px; font-size: 0.85rem;">View ID Document (PDF)</a>
                          <% } else { %>
                            <a href="<%= pro.aadhaarPanUrl %>" target="_blank">
                              <img src="<%= pro.aadhaarPanUrl %>" alt="Aadhaar/PAN" style="max-width: 240px; max-height: 150px; border-radius: var(--radius-sm); border: 1px solid var(--line-strong); object-fit: contain;">
                            </a>
                          <% } %>
                        </div>
                      <% } %>

                      <% if (pro.livePhotoUrl) { %>
                        <div style="display: grid; gap: 0.5rem;">
                          <span style="font-size: 0.8rem; font-weight: 700; color: var(--text-soft); text-transform: uppercase;">Live Photo (Camera Capture)</span>
                          <a href="<%= pro.livePhotoUrl %>" target="_blank">
                            <img src="<%= pro.livePhotoUrl %>" alt="Live Photo" style="width: 150px; height: 150px; border-radius: var(--radius-sm); border: 1px solid var(--line-strong); object-fit: cover;">
                          </a>
                        </div>
                      <% } %>
                    </div>
                  </div>
                <% } %>

                <div style="display: flex; justify-content: flex-end; gap: 1rem; border-top: 1px solid rgba(0,0,0,0.05); padding-top: 1rem; margin-top: 0.5rem;">
                  <!-- Toggle Verification -->
                  <form action="/admin/professionals/<%= pro.id %>/verify" method="POST">
                    <input type="hidden" name="isVerified" value="<%= pro.isVerified ? 'false' : 'true' %>">
                    <button type="submit" class="button <%= pro.isVerified ? 'button-secondary' : 'button-primary' %>" style="font-size: 0.9rem; padding: 0.5rem 1rem;">
                      <%= pro.isVerified ? 'Revoke Verification' : 'Approve & Verify' %>
                    </button>
                  </form>

                  <!-- Delete Profile -->
                  <form action="/admin/professionals/<%= pro.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to permanently delete this professional profile?');">
                    <button type="submit" class="button button-danger" style="font-size: 0.9rem; padding: 0.5rem 1rem; background: rgba(220, 53, 69, 0.1); color: #dc3545; border: 1px solid rgba(220, 53, 69, 0.2);">
                      Reject / Delete
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- SECTION 3: Manage Department / Service Costs -->
    <div class="glass-panel" style="padding: 2.5rem; border-radius: var(--radius-large);">
      <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 1.5rem; margin-bottom: 2rem;">
        <h2 style="font-family: var(--font-display); margin-bottom: 0.25rem;">Department / Service Costs</h2>
        <p style="color: var(--color-ink-light); font-size: 0.95rem;">Set the standard price for each platform service category. These rates apply to all professionals offering these services.</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
        <% dashboardData.services.forEach(function (service) { %>
          <div style="padding: 1.5rem; border-radius: var(--radius-medium); background: rgba(255, 255, 255, 0.45); border: 1px solid var(--color-border); display: flex; flex-direction: column; justify-content: space-between; gap: 1rem;">
            <div>
              <h3 style="font-family: var(--font-display); font-size: 1.15rem; color: var(--color-ink); margin-bottom: 0.25rem;"><%= service.name %></h3>
              <p style="font-size: 0.85rem; color: var(--color-ink-light);">Slug: <%= service.slug %></p>
            </div>

            <form action="/admin/services/<%= service.id %>/price" method="POST" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label class="field-group" style="margin-bottom: 0;">
                <span style="font-size: 0.8rem; font-weight: 600;">Base price (INR):</span>
                <input type="number" name="basePrice" value="<%= service.basePriceInr %>" min="0" max="100000" required style="padding: 0.5rem; border-radius: var(--radius-small);">
              </label>
              <button type="submit" class="button button-primary" style="font-size: 0.85rem; padding: 0.5rem; align-self: flex-end; width: 100%;">Update Price</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>
