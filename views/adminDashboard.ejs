<section class="page-hero">
  <div class="shell page-hero-content">
    <p class="eyebrow">Super Admin Dashboard</p>
    <h1>Welcome, Administrator</h1>
    <p>Manage support tickets, review partner registrations, and oversee site metrics.</p>
  </div>
</section>

<section class="section shell">
  <%- include("partials/notice") %>

  <!-- Overview Stats Grid -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.25rem; margin-bottom: 3rem;">
    <div style="padding: 1.5rem; border-radius: var(--radius-lg); background: rgba(139, 92, 246, 0.12); border: 1px solid rgba(139, 92, 246, 0.3); text-align: center;">
      <strong style="display: block; font-size: 2.5rem; font-family: 'Outfit', sans-serif; color: #a78bfa; margin-bottom: 0.25rem;"><%= dashboardData.metrics.totalClients %></strong>
      <p style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin: 0;">Total Clients</p>
    </div>
    <div style="padding: 1.5rem; border-radius: var(--radius-lg); background: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.3); text-align: center;">
      <strong style="display: block; font-size: 2.5rem; font-family: 'Outfit', sans-serif; color: #22d3ee; margin-bottom: 0.25rem;"><%= dashboardData.metrics.totalProfessionals %></strong>
      <p style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin: 0;">Active Partners</p>
    </div>
    <div style="padding: 1.5rem; border-radius: var(--radius-lg); background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); text-align: center;">
      <strong style="display: block; font-size: 2.5rem; font-family: 'Outfit', sans-serif; color: #34d399; margin-bottom: 0.25rem;"><%= dashboardData.metrics.totalBookings %></strong>
      <p style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin: 0;">Total Bookings</p>
    </div>
    <div style="padding: 1.5rem; border-radius: var(--radius-lg); background: rgba(244, 63, 94, 0.1); border: 1px solid rgba(244, 63, 94, 0.3); text-align: center;">
      <strong style="display: block; font-size: 2.5rem; font-family: 'Outfit', sans-serif; color: #fb7185; margin-bottom: 0.25rem;"><%= dashboardData.metrics.pendingSupport %></strong>
      <p style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin: 0;">Pending Tickets</p>
    </div>
  </div>

  <div style="display: grid; gap: 3rem;">

    <!-- SECTION 1: Support Inbox -->
    <div style="padding: 2rem; border-radius: var(--radius-xl); background: rgba(22, 32, 58, 0.9); border: 1px solid var(--line-strong); backdrop-filter: blur(20px);">
      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--line-strong); padding-bottom: 1.25rem; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <h2 style="font-family: 'Outfit', sans-serif; color: var(--text); margin: 0 0 0.25rem;">Support &amp; Inquiry Inbox</h2>
          <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">Answer queries and review platform support requests.</p>
        </div>
      </div>

      <% if (!dashboardData.supportMessages.length) { %>
        <p style="text-align: center; color: var(--text-soft); padding: 3rem 0;">No support inquiries found in the database.</p>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          <% dashboardData.supportMessages.forEach(function (msg) { %>
            <div style="padding: 1.5rem; border-radius: var(--radius-md); background: rgba(15, 23, 42, 0.7); border: 1px solid var(--line-strong); display: flex; flex-direction: column; gap: 1rem;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
                <div>
                  <span style="display: inline-block; padding: 0.2rem 0.65rem; font-size: 0.75rem; font-weight: 700; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;
                    <%= msg.status === 'resolved' ? 'background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.3);' : 'background: rgba(244,63,94,0.15); color: #fb7185; border: 1px solid rgba(244,63,94,0.3);' %>">
                    <%= msg.status === 'resolved' ? 'Resolved' : 'Pending Action' %>
                  </span>
                  <h3 style="font-family: 'Outfit', sans-serif; font-size: 1.1rem; color: var(--text); margin: 0 0 0.25rem;"><%= msg.subject || "No Subject" %></h3>
                  <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">
                    From: <strong style="color: var(--text);"><%= msg.full_name %></strong> (<%= msg.email %>)
                    <% if (msg.phone) { %> | Phone: <%= msg.phone %><% } %>
                  </p>
                </div>
                <span style="font-size: 0.8rem; color: var(--text-soft); white-space: nowrap;"><%= formatShortDate(msg.created_at) %></span>
              </div>

              <div style="padding: 1rem; border-radius: var(--radius-sm); background: rgba(255,255,255,0.04); border-left: 3px solid var(--accent); font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;">
                <%= msg.message %>
              </div>

              <% if (msg.status === 'resolved') { %>
                <div style="padding: 1rem; border-radius: var(--radius-sm); background: rgba(16,185,129,0.07); border: 1px solid rgba(16,185,129,0.2);">
                  <p style="font-size: 0.8rem; color: #34d399; font-weight: 700; margin: 0 0 0.5rem;">Admin Response (replied on <%= formatShortDate(msg.replied_at) %>):</p>
                  <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; margin: 0;"><%= msg.admin_reply %></p>
                </div>
              <% } else { %>
                <form action="/admin/support/<%= msg.id %>/reply" method="POST" style="display: flex; flex-direction: column; gap: 0.75rem;">
                  <label class="field-group" style="margin-bottom: 0;">
                    <span style="font-weight: 600; font-size: 0.85rem; color: var(--text-muted);">Write official reply:</span>
                    <textarea name="replyText" rows="3" placeholder="Write response to user..." required style="padding: 1rem; border-radius: var(--radius-sm); resize: vertical;"></textarea>
                  </label>
                  <button type="submit" class="button button-primary" style="align-self: flex-end;">Save &amp; Resolve Ticket</button>
                </form>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- SECTION 2: Professional Partner Registrations -->
    <div style="padding: 2rem; border-radius: var(--radius-xl); background: rgba(22, 32, 58, 0.9); border: 1px solid var(--line-strong); backdrop-filter: blur(20px);">
      <div style="border-bottom: 1px solid var(--line-strong); padding-bottom: 1.25rem; margin-bottom: 2rem;">
        <h2 style="font-family: 'Outfit', sans-serif; color: var(--text); margin: 0 0 0.25rem;">Partner Registrations</h2>
        <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">Review, verify, or remove registered service professionals.</p>
      </div>

      <% if (!dashboardData.professionals.length) { %>
        <p style="text-align: center; color: var(--text-soft); padding: 3rem 0;">No professional applications or profiles registered yet.</p>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          <% dashboardData.professionals.forEach(function (pro) { %>
            <div style="padding: 1.75rem; border-radius: var(--radius-lg); background: rgba(15, 23, 42, 0.7); border: 1px solid var(--line-strong); display: grid; grid-template-columns: auto 1fr; gap: 1.5rem; align-items: start;">
              <img src="<%= encodeURI(pro.photo) %>" alt="<%= pro.name %>" style="width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent-soft);">
              
              <div style="display: flex; flex-direction: column; gap: 1rem; min-width: 0;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.75rem;">
                  <div>
                    <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.25rem;">
                      <h3 style="font-family: 'Outfit', sans-serif; font-size: 1.2rem; color: var(--text); margin: 0;"><%= pro.name %></h3>
                      <span style="font-size: 0.7rem; padding: 0.15rem 0.55rem; border-radius: 99px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
                        <%= pro.isVerified ? 'background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.3);' : 'background: rgba(244,63,94,0.15); color: #fb7185; border: 1px solid rgba(244,63,94,0.3);' %>">
                        <%= pro.isVerified ? 'Verified Partner' : 'Pending Verification' %>
                      </span>
                    </div>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">
                      Email: <%= pro.email %> | Phone: <%= pro.phone %> | City: <%= pro.city %> (<%= pro.area %>)
                    </p>
                  </div>
                </div>

                <div style="display: flex; gap: 1.5rem; font-size: 0.85rem; color: var(--text-muted); border-top: 1px solid var(--line-strong); border-bottom: 1px solid var(--line-strong); padding: 0.6rem 0;">
                  <span><strong style="color: var(--text);">Experience:</strong> <%= pro.experience %> Years</span>
                  <span><strong style="color: var(--text);">Starting rate:</strong> <%= formatCurrency(pro.startingPrice) %></span>
                </div>

                <div>
                  <h4 style="font-size: 0.8rem; font-weight: 700; margin: 0 0 0.5rem; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.05em;">Skills / Categories:</h4>
                  <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
                    <% pro.skills.forEach(function (skill) { %>
                      <span style="font-size: 0.78rem; padding: 0.2rem 0.65rem; border-radius: 99px; background: var(--accent-soft); border: 1px solid rgba(139,92,246,0.25); color: #c4b5fd; font-weight: 600;"><%= skill %></span>
                    <% }) %>
                  </div>
                </div>

                <% if (pro.description) { %>
                  <div>
                    <h4 style="font-size: 0.8rem; font-weight: 700; margin: 0 0 0.35rem; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.05em;">Bio:</h4>
                    <p style="font-size: 0.9rem; line-height: 1.6; color: var(--text-muted); margin: 0;"><%= pro.description %></p>
                  </div>
                <% } %>

                <% if (pro.aadhaarPanUrl || pro.livePhotoUrl) { %>
                  <div style="border-top: 1px dashed var(--line-strong); padding-top: 1rem;">
                    <h4 style="font-size: 0.85rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text);">Identity Verification Documents:</h4>
                    <div style="display: flex; gap: 2rem; align-items: flex-start; flex-wrap: wrap;">
                      <% if (pro.aadhaarPanUrl) { %>
                        <div style="display: grid; gap: 0.6rem; background: rgba(255,255,255,0.03); padding: 1rem; border-radius: var(--radius-md); border: 1px solid var(--line-strong);">
                          <span style="font-size: 0.78rem; font-weight: 700; color: var(--text-soft); text-transform: uppercase;">ID Document (Aadhaar/PAN)</span>
                          <% 
                            const idUrl = pro.aadhaarPanUrl;
                            const isPlaceholderId = (idUrl === 'Aadhaar/PAN' || idUrl === 'Live Photo' || (!idUrl.startsWith('/') && !idUrl.startsWith('http') && !idUrl.startsWith('data:')));
                          %>
                          <% if (isPlaceholderId) { %>
                            <span style="font-size: 0.82rem; color: #fb7185; background: rgba(244,63,94,0.1); padding: 6px 10px; border-radius: 6px;">⚠️ Pending actual file upload (Current value: <%= idUrl %>)</span>
                          <% } else if (idUrl.toLowerCase().endsWith('.pdf')) { %>
                            <a href="<%= idUrl %>" target="_blank" class="button button-secondary" style="min-height: 38px; padding: 0 14px; font-size: 0.82rem;">📄 View ID Document (PDF)</a>
                          <% } else { %>
                            <a href="<%= idUrl %>" target="_blank" style="display: block; text-decoration: none;">
                              <img src="<%= idUrl %>" alt="Aadhaar/PAN Document" style="max-width: 220px; max-height: 140px; border-radius: var(--radius-sm); border: 1px solid var(--line-strong); object-fit: contain;">
                            </a>
                            <a href="<%= idUrl %>" target="_blank" style="font-size: 0.8rem; color: #38bdf8; text-decoration: underline;">Open Document in New Tab</a>
                          <% } %>
                        </div>
                      <% } %>

                      <% if (pro.livePhotoUrl) { %>
                        <div style="display: grid; gap: 0.6rem; background: rgba(255,255,255,0.03); padding: 1rem; border-radius: var(--radius-md); border: 1px solid var(--line-strong);">
                          <span style="font-size: 0.78rem; font-weight: 700; color: var(--text-soft); text-transform: uppercase;">Live Photo</span>
                          <% 
                            const photoUrl = pro.livePhotoUrl;
                            const isPlaceholderPhoto = (photoUrl === 'Aadhaar/PAN' || photoUrl === 'Live Photo' || (!photoUrl.startsWith('/') && !photoUrl.startsWith('http') && !photoUrl.startsWith('data:')));
                          %>
                          <% if (isPlaceholderPhoto) { %>
                            <span style="font-size: 0.82rem; color: #fb7185; background: rgba(244,63,94,0.1); padding: 6px 10px; border-radius: 6px;">⚠️ Pending actual file upload (Current value: <%= photoUrl %>)</span>
                          <% } else { %>
                            <a href="<%= photoUrl %>" target="_blank" style="display: block; text-decoration: none;">
                              <img src="<%= photoUrl %>" alt="Live Photo" style="width: 140px; height: 140px; border-radius: var(--radius-sm); border: 1px solid var(--line-strong); object-fit: cover;">
                            </a>
                            <a href="<%= photoUrl %>" target="_blank" style="font-size: 0.8rem; color: #38bdf8; text-decoration: underline;">Open Photo in New Tab</a>
                          <% } %>
                        </div>
                      <% } %>
                    </div>
                  </div>
                <% } %>

                <div style="display: flex; justify-content: flex-end; gap: 0.75rem; border-top: 1px solid var(--line-strong); padding-top: 1rem; margin-top: 0.25rem; flex-wrap: wrap;">
                  <form action="/admin/professionals/<%= pro.id %>/verify" method="POST">
                    <input type="hidden" name="isVerified" value="<%= pro.isVerified ? 'false' : 'true' %>">
                    <button type="submit" class="button <%= pro.isVerified ? 'button-secondary' : 'button-primary' %>" style="min-height: 40px; padding: 0 18px; font-size: 0.88rem;">
                      <%= pro.isVerified ? 'Revoke Verification' : 'Approve & Verify' %>
                    </button>
                  </form>
                  <form action="/admin/professionals/<%= pro.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to permanently delete this professional profile?');">
                    <button type="submit" style="min-height: 40px; padding: 0 18px; font-size: 0.88rem; border-radius: 999px; background: rgba(244,63,94,0.1); color: #fb7185; border: 1px solid rgba(244,63,94,0.3); cursor: pointer; font-weight: 600; transition: all 0.2s;" onmouseover="this.style.background='rgba(244,63,94,0.2)'" onmouseout="this.style.background='rgba(244,63,94,0.1)'">
                      Reject / Delete
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Removed Department / Service Costs section since professionals set their own prices -->
  </div>
</section>
