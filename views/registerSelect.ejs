<section class="section shell auth-layout" style="max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 2rem;">
  <div class="glass-panel" style="width: 100%; text-align: center; padding: 2rem; border-radius: var(--radius-large);">
    <p class="eyebrow">Join SV Personnels</p>
    <h1 style="font-family: var(--font-display); font-size: 2.2rem; margin-bottom: 0.5rem; color: var(--color-ink);">Create your account</h1>
    <p style="color: var(--color-ink-light); max-width: 600px; margin: 0 auto;">Choose how you want to use the platform to get started.</p>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr)); gap: 2rem; width: 100%;">
    <!-- Option 1: Client -->
    <div class="glass-panel card-reveal" style="padding: 2.5rem; border-radius: var(--radius-large); display: flex; flex-direction: column; justify-content: space-between; align-items: center; text-align: center; background: rgba(255,255,255,0.45); transition: transform 0.3s ease, border-color 0.3s ease;">
      <div>
        <div style="font-size: 3.5rem; margin-bottom: 1.5rem;">🔍</div>
        <h2 style="font-family: var(--font-display); font-size: 1.6rem; margin-bottom: 0.75rem; color: var(--color-ink);">I want to hire</h2>
        <p style="color: var(--color-ink-light); font-size: 0.95rem; line-height: 1.6; margin-bottom: 2rem;">Find and book verified local professionals for cleaning, repair, tutoring, and more. Simple booking, secure process.</p>
      </div>
      <a href="/signup" class="button button-primary button-block" style="text-decoration: none;">Register as a Client</a>
    </div>

    <!-- Option 2: Professional -->
    <div class="glass-panel card-reveal" style="padding: 2.5rem; border-radius: var(--radius-large); display: flex; flex-direction: column; justify-content: space-between; align-items: center; text-align: center; background: rgba(255,255,255,0.45); transition: transform 0.3s ease, border-color 0.3s ease;">
      <div>
        <div style="font-size: 3.5rem; margin-bottom: 1.5rem;">💼</div>
        <h2 style="font-family: var(--font-display); font-size: 1.6rem; margin-bottom: 0.75rem; color: var(--color-ink);">I want to offer services</h2>
        <p style="color: var(--color-ink-light); font-size: 0.95rem; line-height: 1.6; margin-bottom: 2rem;">Grow your local service business, get verified booking requests from clients, and manage your schedule easily.</p>
      </div>
      <a href="/register/professional" class="button button-secondary button-block" style="text-decoration: none;">Register as a Partner</a>
    </div>
  </div>

  <p style="color: var(--color-ink-light); font-size: 0.95rem; margin-top: 1rem;">
    Already have an account? <a href="/login" style="color: var(--color-brand); font-weight: 600; text-decoration: none;">Log in here</a>
  </p>
</section>
