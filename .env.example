PORT=3000
SESSION_SECRET=replace-with-a-secure-session-secret

# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Optional aliases used by the Express server (same values as above)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-publishable-key-here

# Optional: service role key for unrestricted server access
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
